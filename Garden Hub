	corner(box, 5)

	local tick = Instance.new("Frame")
	tick.AnchorPoint      = Vector2.new(0.5, 0.5)
	tick.Position         = UDim2.fromScale(0.5, 0.5)
	tick.BackgroundColor3 = Theme.Accent
	tick.BorderSizePixel  = 0
	tick.Parent           = box
	corner(tick, 3)

	local state = default and true or false
	local function render(animate)
		local info = animate and TW_FAST or TweenInfo.new(0)
		tw(tick, info, { Size = state and UDim2.fromOffset(12, 12) or UDim2.fromOffset(0, 0) })
		tw(box, info, { BackgroundColor3 = state and Color3.fromRGB(60, 30, 33) or Theme.Off })
	end
	render(false)

	track(holder.MouseButton1Click:Connect(function()
		state = not state
		render(true)
		if onChanged then onChanged(state) end
	end))
	return holder, function() return state end, function(v) state = v; render(true); if onChanged then onChanged(v) end end
end

function Library:AddLabel(tab, text)
	local lbl = Instance.new("TextLabel")
	lbl.Size             = UDim2.new(1, 0, 0, 18)
	lbl.BackgroundTransparency = 1
	lbl.Font             = Enum.Font.GothamBold
	lbl.TextSize         = 11
	lbl.TextColor3       = Theme.SubText
	lbl.TextXAlignment   = Enum.TextXAlignment.Left
	lbl.Text             = string.upper(text)
	lbl.Parent           = tab.page
	return lbl
end

function Library:AddTextBox(tab, text, placeholder, onSubmit)
	local holder = Instance.new("Frame")
	holder.Size             = UDim2.new(1, 0, 0, 38)
	holder.BackgroundColor3 = Theme.Row
	holder.BorderSizePixel  = 0
	holder.Parent           = tab.page
	corner(holder, 8)

	local lbl = Instance.new("TextLabel")
	lbl.Size             = UDim2.new(0.5, -8, 1, 0)
	lbl.Position         = UDim2.fromOffset(12, 0)
	lbl.BackgroundTransparency = 1
	lbl.Font             = Enum.Font.GothamSemibold
	lbl.TextSize         = 13
	lbl.TextColor3       = Theme.Text
	lbl.TextXAlignment   = Enum.TextXAlignment.Left
	lbl.Text             = text
	lbl.Parent           = holder

	local box = Instance.new("TextBox")
	box.Size             = UDim2.new(0.5, -8, 0, 28)
	box.Position         = UDim2.new(0.5, 0, 0.5, -14)
	box.BackgroundColor3 = Theme.BG
	box.BorderSizePixel  = 0
	box.Font             = Enum.Font.Gotham
	box.TextSize         = 12
	box.TextColor3       = Theme.Text
	box.PlaceholderText  = placeholder or ""
	box.PlaceholderColor3 = Theme.SubText
	box.Text             = ""
	box.ClearTextOnFocus = false
	box.Parent           = holder
	corner(box, 6)
	stroke(box, Theme.AccentDk, 1, 0.4)

	track(box.FocusLost:Connect(function(enterPressed)
		if enterPressed and onSubmit then
			onSubmit(box.Text)
		end
	end))
	return holder, box
end

