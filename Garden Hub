-- Hardened parse: handles single-word names AND multi-token names that may
-- carry underscores (e.g. WildPet_Golden_Dragonfly_WildPet_xxxx -> "Golden_Dragonfly").
local function petInfo(model)
	local name = model:GetAttribute("PetName")
		or model.Name:match("^WildPet_(.-)_WildPet_")
		or model.Name:match("^WildPet_(.+)$")
		or model.Name
	local id = model.Name:match("WildPet_.-_WildPet_(.+)")
	return name, id
end

local function petMatchesFilters(model)
	local name = petInfo(model)
	if next(selectedPetNames) == nil then return true end
	return selectedPetNames[name] == true
end

