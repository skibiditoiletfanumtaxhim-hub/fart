task.spawn(function()
	while running do
		task.wait(0.3)
		if running and STAY_IN_CENTER
			and not stealing and not collecting and not petTaming and not taming then
			local hrp = getHRP()
			local center = getGardenCenterCFrame()
			if hrp and center then
				local d = hrp.Position - center.Position
				if Vector3.new(d.X, 0, d.Z).Magnitude > 8 then
					hrp.CFrame = center
				end
			end
		end
	end
end)

