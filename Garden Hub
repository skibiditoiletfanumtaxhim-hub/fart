-- CAPTURE TOOL
--==================================================================
local captureInstalled = false
local CAPTURE_DENYLIST = {
    ["Garden.CollectFruit"] = true, ["SeedShop.PurchaseSeed"] = true,
    ["GearShop.PurchaseGear"] = true, ["CrateShop.PurchaseCrate"] = true,
    ["NPCS.SellAll"] = true,
}

local function installCapture(focused)
    local keywords = focused and { "pet", "tame", "wild", "steal" } or nil
    if captureInstalled then
        print("[Capture] Already installed. Keywords: " .. (focused and "FOCUSED" or "all"))
        return
    end
    captureInstalled = true
    local count = 0
    local lastPrint = {}
    for sName, service in pairs(Networking) do
        if type(service) == "table" then
            local function wrap(label, remote)
                local orig = remote.Fire
                if type(orig) ~= "function" then return end
                remote.Fire = function(self, ...)
                    if not CAPTURE_DENYLIST[label] then
                        local pass = true
                        if keywords then
                            pass = false
                            local low = label:lower()
                            for _, kw in ipairs(keywords) do
                                if low:find(kw, 1, true) then pass = true; break end
                            end
                        end
                        if pass then
                            local now = os.clock()
                            if (now - (lastPrint[label] or -math.huge)) >= 0.5 then
                                lastPrint[label] = now
                                local n = select("#", ...)
                                local parts = {}
                                for i = 1, n do
                                    local v = select(i, ...)
                                    local t = typeof(v)
                                    parts[i] = t == "Instance"
                                        and string.format("[%d] %s = %s", i, t, v:GetFullName())
                                        or  string.format("[%d] %s = %s", i, t, tostring(v))
                                end
                                print("[CAPTURE] " .. label .. ":Fire(" .. table.concat(parts, ", ") .. ")")
                            end
                        end
                    end
                    return orig(self, ...)
                end
                count += 1
            end
            if type(service.Fire) == "function" and service.Id ~= nil then
                wrap(sName, service)
            else
                for rName, remote in pairs(service) do
                    if type(remote) == "table" and type(remote.Fire) == "function" then
                        wrap(sName .. "." .. rName, remote)
                    end
                end
            end
        end
    end
    print(string.format("[Capture] Installed on %d remotes.", count))
    Rayfield:Notify({ Title = "Capture", Content = string.format("Hooked %d remotes. Check output.", count), Duration = 4 })
end

