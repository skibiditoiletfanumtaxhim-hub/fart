local function findWildPetsFolder()
	local map = Workspace:FindFirstChild("Map")
	if not map then return nil end
	return map:FindFirstChild("WildPetSpawns")
		or map:FindFirstChild("WildPets")
		or map:FindFirstChild("WildPetSpawn")
		or Workspace:FindFirstChild("WildPetSpawns")
		or nil
end

local function debugWildPets()
	local folder = findWildPetsFolder()
	if not folder then
		warn("[Pets] No wild pet folder found. Children of Map:")
		local map = Workspace:FindFirstChild("Map")
		if map then
			for _, c in ipairs(map:GetChildren()) do
				print("   Map > " .. c.Name .. "  (" .. c.ClassName .. ")")
			end
		else
			warn("   Workspace.Map itself is missing.")
		end
		return
	end
	print("[Pets] Found folder: " .. folder:GetFullName())
	local kids = folder:GetChildren()
	print("[Pets] " .. #kids .. " children.")
	for i, m in ipairs(kids) do
		if i > 5 then print("   ... (truncated)"); break end
		print(string.format("   [%d] %s (%s)", i, m.Name, m.ClassName))
		local prompt = m:FindFirstChildWhichIsA("ProximityPrompt", true)
		print("        prompt: " .. (prompt and prompt:GetFullName() or "NONE FOUND"))
	end
end

local function petInfo(model)
	local name = model:GetAttribute("PetName") or model.Name:match("WildPet_([^_]+)") or model.Name
	local id   = model.Name:match("WildPet_[^_]+_WildPet_(.+)")
	return name, id
end

local function petMatchesFilters(model)
	local name = petInfo(model)
	if next(selectedPetNames) == nil then return true end
	return selectedPetNames[name] == true
end

local function findWildPetRefFolder()
	local map = Workspace:FindFirstChild("Map")
	return map and map:FindFirstChild("WildPetRef") or nil
end

-- Resolve a spawn model (which carries the pet type for filtering) to the ref
-- part in Workspace.Map.WildPetRef that WildPetTame actually wants.
local function getPetRefPart(model)
	local refFolder = findWildPetRefFolder()
	if not refFolder then return nil end

	local _, id = petInfo(model)
	if id then
		local exact = refFolder:FindFirstChild("WildPet_" .. id)
		if exact then return exact end
		for _, p in ipairs(refFolder:GetChildren()) do
			if p.Name:find(id, 1, true) then return p end
		end
	end

	local modelPart = model:FindFirstChild("RootPart") or model:FindFirstChildWhichIsA("BasePart", true)
	if modelPart then
		local best, bestDist
		for _, p in ipairs(refFolder:GetChildren()) do
			if p:IsA("BasePart") then
				local d = (p.Position - modelPart.Position).Magnitude
				if not bestDist or d < bestDist then best, bestDist = p, d end
			end
		end
		if best and bestDist and bestDist < 30 then return best end
	end
	return nil
end

local function enterTame()
	tameDepth += 1
	petTaming = true
end
local function exitTame()
	tameDepth = math.max(0, tameDepth - 1)
	if tameDepth == 0 then petTaming = false end
end

-- Per-part cooldown: don't keep teleporting to a pet that won't tame (e.g. full
-- pet slots). Weak keys so tamed/removed parts clear themselves.
local tameCooldown = setmetatable({}, { __mode = "k" })
local TAME_RETRY   = 5

-- Fire WildPetTame on a ref part. WildPetTame is distance-checked server-side,
-- so if TAME_TELEPORT is on we hop to the pet, fire, and hop back.
local TAME_WALKSPEED = 60    -- lower = less likely to ram parts; raise if too slow
local tameWarned = false

local function fireTameAt(part)
	if not (part and (part:IsA("BasePart") or part:IsA("Model"))) then return end

	local now = os.clock()
	if (now - (tameCooldown[part] or -math.huge)) < TAME_RETRY then return end
	tameCooldown[part] = now

	local char = character or player.Character
	local hrp  = char and char:FindFirstChild("HumanoidRootPart")
	local hum  = char and char:FindFirstChildWhichIsA("Humanoid")
	if not (hrp and hum) then return end

	taming = true
	enterTame()
	petTaming = true

	local pos = part:IsA("BasePart") and part.Position or part:GetPivot().Position
	local originalSpeed = hum.WalkSpeed

	-- Disable collisions on the character so we don't ram parts and get flung.
	local restoreCollide = {}
	for _, d in ipairs(char:GetDescendants()) do
		if d:IsA("BasePart") and d.CanCollide then
			restoreCollide[d] = true
			d.CanCollide = false
		end
	end

	hum.WalkSpeed = TAME_WALKSPEED

	local arrived = false
	local conn = hum.MoveToFinished:Connect(function(reached) arrived = reached end)
	hum:MoveTo(pos)

	local waited = 0
	while not arrived and waited < 3 do
		hum:MoveTo(pos)
		task.wait(0.1)
		waited += 0.1
		-- Full 3D distance now, not just horizontal.
		if (hrp.Position - pos).Magnitude < 10 then arrived = true end
	end
	conn:Disconnect()

	-- Fire a few times over ~0.4s while parked, so a single mistimed fire
	-- doesn't make us miss the pet.
	for _ = 1, 4 do
		pcall(function() Networking.Pets.WildPetTame:Fire(part) end)
		task.wait(0.1)
	end

	-- Restore collisions.
	for d in pairs(restoreCollide) do
		if d and d.Parent then d.CanCollide = true end
	end

	hum.WalkSpeed = originalSpeed
	taming = false
	exitTame()
	petTaming = false
end

local function tameWildPet(model)
	fireTameAt(getPetRefPart(model))
end

local function autoTamePets()
	local refFolder = findWildPetRefFolder()
	if not refFolder then return end
	enterTame()

	if next(selectedPetNames) == nil then
		for _, part in ipairs(refFolder:GetChildren()) do
			if not (running and AUTO_PETS) then break end
			fireTameAt(part)
		end
		exitTame()
		return
	end

	local spawnFolder = findWildPetsFolder()
	if not spawnFolder then exitTame() return end
	for _, model in ipairs(spawnFolder:GetChildren()) do
		if not (running and AUTO_PETS) then break end
		if (model:IsA("Model") or model:IsA("Folder")) and petMatchesFilters(model) then
			tameWildPet(model)
		end
	end
	exitTame()
end

local function testTameFirstPet()
	local folder = findWildPetsFolder()
	if not folder then warn("[Pets] No wild pet folder found.") return end
	for _, model in ipairs(folder:GetChildren()) do
		if (model:IsA("Model") or model:IsA("Folder")) and petMatchesFilters(model) then
			local name = petInfo(model)
			local refPart = getPetRefPart(model)
			if not refPart then
				warn("[Pets] Couldn't find a WildPetRef part for " .. model.Name)
				return
			end
			print("[Pets] Taming " .. tostring(name) .. " via " .. refPart:GetFullName()
				.. (TAME_TELEPORT and "  (teleport ON)" or "  (teleport OFF)"))
			tameCooldown[refPart] = nil -- allow an immediate manual test
			task.spawn(function() fireTameAt(refPart) end)
			return
		end
	end
	warn("[Pets] No matching wild pets to test on.")
end

local captureInstalled = false
local CAPTURE_DENYLIST = {
	["Garden.CollectFruit"] = true,
	["SeedShop.PurchaseSeed"] = true,
	["GearShop.PurchaseGear"] = true,
	["CrateShop.PurchaseCrate"] = true,
	["NPCS.SellAll"] = true,
	["ObjectPositionService.CreateServerValue"] = true,
    ["Steal.BeginSteal"] = true,
}

local function describeArg(i, v)
	local t = typeof(v)
	if t == "Instance" then
		return string.format("[%d] Instance(%s) = %s", i, v.ClassName, v:GetFullName())
	elseif t == "table" then
		local ok, encoded = pcall(function() return HttpService:JSONEncode(v) end)
		return string.format("[%d] table = %s", i, ok and encoded or "<unencodable table>")
	else
		return string.format("[%d] %s = %s", i, t, tostring(v))
	end
end

local captureLastPrint = {}
local captureKeywords = nil
local function labelMatchesFilter(label)
	if not captureKeywords then return true end
	local low = label:lower()
	for _, kw in ipairs(captureKeywords) do
		if low:find(kw, 1, true) then return true end
	end
	return false
end

local function wrapRemoteFire(label, remote)
	local orig = remote.Fire
	if type(orig) ~= "function" then return end
	remote.Fire = function(selfRef, ...)
		if not CAPTURE_DENYLIST[label] and labelMatchesFilter(label) then
			local now = os.clock()
			if (now - (captureLastPrint[label] or -math.huge)) >= 1 then
				captureLastPrint[label] = now
				local n = select("#", ...)
				local parts = {}
				for i = 1, n do
					parts[i] = describeArg(i, (select(i, ...)))
				end
				pcall(function()
					print("[CAPTURE] " .. label .. ":Fire(" .. table.concat(parts, ", ") .. ")")
				end)
			end
		end
		return orig(selfRef, ...)
	end
end

local function installCapture(focused)
	captureKeywords = focused and { "pet", "tame", "wild", "steal" } or nil

	if captureInstalled then
		print("[Capture] Filter set to: " .. (focused and "PET/STEAL-ONLY" or "everything"))
		return
	end
	captureInstalled = true
	local count = 0
	for serviceName, service in pairs(Networking) do
		if type(service) == "table" then
			if type(service.Fire) == "function" and service.Id ~= nil then
				wrapRemoteFire(serviceName, service); count += 1
			else
				for remoteName, remote in pairs(service) do
					if type(remote) == "table" and type(remote.Fire) == "function" then
						wrapRemoteFire(serviceName .. "." .. remoteName, remote); count += 1
					end
				end
			end
		end
	end
	print(string.format("[Capture] Installed on %d remotes. Filter: %s", count, focused and "FOCUSED" or "everything"))
end

