--==================================================================
-- CORE LOGIC
--==================================================================
local function firePrompt(prompt)
	if not prompt or not prompt:IsA("ProximityPrompt") then return end
	if not prompt.Enabled then return end
	if prompt.ActionText == "" and prompt.ObjectText == "" then return end
	pcall(function()
		prompt.MaxActivationDistance = math.huge
		prompt.RequiresLineOfSight   = false
		prompt.HoldDuration          = 0
		prompt:InputHoldBegin()
		prompt:InputHoldEnd()
	end)
end

local function getHRP()
	local char = character or player.Character
	return char and char:FindFirstChild("HumanoidRootPart") or nil
end

local function getMyGarden()
	local gardens = Workspace:FindFirstChild("Gardens")
	if not gardens then return nil end
	for _, model in ipairs(gardens:GetChildren()) do
		if model:GetAttribute("Owner") == player.Name then return model end
	end
	return nil
end

local function activateHarvestPrompts()
	local garden = getMyGarden();
	if not garden then return end
	local plants = garden:FindFirstChild("Plants");  if not plants then return end

	-- The game uses StreamingEnabled, so when you walk away from the garden the
	-- plant/fruit instances get unloaded on your client and this loop finds
	-- almost nothing to collect (the "super slow when far" symptom). Ask the
	-- engine to stream the garden in around its position WITHOUT moving the
	-- character. This is a no-op if streaming is off, so it's always safe.
	pcall(function()
		local pos = garden:GetPivot().Position
		player:RequestStreamAroundAsync(pos)
	end)

	for _, plant in ipairs(plants:GetChildren()) do
		if not (enabled and running) then break end
		local plantId = plant:GetAttribute("PlantId")
		local fruits  = plant:FindFirstChild("Fruits")
		if plantId and fruits then
			for _, fruit in ipairs(fruits:GetChildren()) do
				local fruitId = fruit:GetAttribute("FruitId")
				if fruitId then
					pcall(function() Networking.Garden.CollectFruit:Fire(plantId, fruitId) end)
				end
			end
		end
		task.wait()
	end
end

local function activateSeedPackPrompts()
	local map = Workspace:FindFirstChild("Map");
	if not map then return end
	local spawns = map:FindFirstChild("SeedPackSpawnServerLocations");  if not spawns then return end
	for _, obj in ipairs(spawns:GetDescendants()) do
		if obj:IsA("ProximityPrompt") then firePrompt(obj) end
	end
end

local function collectSeedPacks()
	local map = Workspace:FindFirstChild("Map");
	if not map then return end
	local spawns = map:FindFirstChild("SeedPackSpawnServerLocations");  if not spawns then return end
	local hrp = getHRP();
	if not hrp then return end
	for _, obj in ipairs(spawns:GetDescendants()) do
		if obj:IsA("ProximityPrompt") and obj.Enabled then
			local part = obj.Parent
			if part and part:IsA("BasePart") then
				local startCFrame = hrp.CFrame
				hrp.CFrame = CFrame.new(part.Position + Vector3.new(0, 3, 0))
				task.wait(TP_SETTLE)
				firePrompt(obj)
				if RETURN_TO_START then
					task.wait(TP_SETTLE)
					hrp.CFrame = startCFrame
				end
			end
		end
	end
end

local function getFruitLabel()
	local pg = player:FindFirstChild("PlayerGui");
	if not pg then return nil end
	local bg = pg:FindFirstChild("BackpackGui");        if not bg then return nil end
	local bp = bg:FindFirstChild("Backpack");
	if not bp then return nil end
	local inv = bp:FindFirstChild("Inventory");
	if not inv then return nil end
	return inv:FindFirstChild("FruitInventory")
end

local function isInventoryFull()
	local label = getFruitLabel()
	if not label or not label:IsA("TextLabel") then return false end
	local clean = label.Text:gsub("<[^>]->", ""):gsub(",", "")
	local cur, max = string.match(clean, "(%d+)%s*/%s*(%d+)")
	cur, max = tonumber(cur), tonumber(max)
	return cur ~= nil and max ~= nil and cur >= max
end

local function stripVisuals()
	local texClasses = { Decal = true, Texture = true, SurfaceAppearance = true }
	local particleClasses = { ParticleEmitter = true, Trail = true, Beam = true, Smoke = true, Fire = true, Sparkles = true }
	local removed, disabled, smoothed = 0, 0, 0
	for _, obj in ipairs(Workspace:GetDescendants()) do
		if texClasses[obj.ClassName] then
			pcall(function() obj:Destroy() end);
			removed += 1
		elseif particleClasses[obj.ClassName] then
			pcall(function() obj.Enabled = false end); disabled += 1
		elseif obj:IsA("BasePart") then
			pcall(function()
				obj.Material      = Enum.Material.SmoothPlastic
				obj.TopSurface    = Enum.SurfaceType.Smooth
				obj.BottomSurface = Enum.SurfaceType.Smooth
				obj.LeftSurface   = Enum.SurfaceType.Smooth
				obj.RightSurface  = Enum.SurfaceType.Smooth
				obj.FrontSurface  = Enum.SurfaceType.Smooth
				obj.BackSurface   = Enum.SurfaceType.Smooth
				if obj:IsA("MeshPart") then obj.TextureID = "" end
			end)
			smoothed += 1
		end
	end
	print(string.format("[AutoHarvest] Removed %d textures, disabled %d effects, smoothed %d parts.", removed, disabled, smoothed))
end

local hiddenParts = {}
local function setOtherPlotsHidden(hide)
	local gardens = Workspace:FindFirstChild("Gardens")
	if not gardens then return end
	if hide then
		for _, model in ipairs(gardens:GetChildren()) do
			if model:GetAttribute("Owner") ~= player.Name then
				for _, obj in ipairs(model:GetDescendants()) do
					if obj:IsA("BasePart") then
						if hiddenParts[obj] == nil then hiddenParts[obj] = obj.Transparency end
						pcall(function() obj.Transparency = 1 end)
					end
				end
			end
		end
	else
		for part, original in pairs(hiddenParts) do
			if part and part.Parent then pcall(function() part.Transparency = original end) end
		end
		table.clear(hiddenParts)
	end
end

--==================================================================
-- CONFIG SYSTEM
-- (Defined AFTER the state variables and setOtherPlotsHidden so that
--  save/load capture the real locals as upvalues instead of nil globals.)
--==================================================================
local CONFIG_FOLDER = "AutoHarvestConfigs"
local DEFAULT_CONFIG_NAME = "default"
local AUTOLOAD_FILE_PATH = CONFIG_FOLDER .. "/autoload_target.txt"

local function getConfigPath(name)
    return CONFIG_FOLDER .. "/" .. (name or DEFAULT_CONFIG_NAME) .. ".json"
end

local function ensureConfigFolder()
    if not isfolder(CONFIG_FOLDER) then
        makefolder(CONFIG_FOLDER)
    end
end

local function saveConfig(name)
    ensureConfigFolder()
    local config = {
        enabled = enabled,
        AUTO_SELL = AUTO_SELL,
        AUTO_COLLECT = AUTO_COLLECT,
        ANTI_AFK = ANTI_AFK,
        HIDE_OTHER_PLOTS = HIDE_OTHER_PLOTS,
        AUTO_PETS = AUTO_PETS,
        autoBuySeeds = autoBuySeeds,
        autoBuyGear = autoBuyGear,
        autoBuyCrates = autoBuyCrates,
        LOOP_INTERVAL = LOOP_INTERVAL,
        POLL_INTERVAL = POLL_INTERVAL,
        COLLECT_INTERVAL = COLLECT_INTERVAL,
        TP_SETTLE = TP_SETTLE,
        RETURN_TO_START = RETURN_TO_START,
        selectedSeeds = selectedSeeds,
        selectedGear = selectedGear,
        selectedCrates = selectedCrates,
        selectedPetNames = selectedPetNames,
    }
    local success, err = pcall(function()
        writefile(getConfigPath(name), HttpService:JSONEncode(config))
    end)
    if success then
        print("[Config] Saved '" .. name .. "'")
        return true
    else
        warn("[Config] Save failed: " .. tostring(err))
        return false
    end
end

local function loadConfig(name)
    local path = getConfigPath(name)
    if not isfile(path) then
        warn("[Config] No config found: '" .. name .. "'")
        return false
    end
    local success, result = pcall(function()
        return HttpService:JSONDecode(readfile(path))
    end)
    if not success or type(result) ~= "table" then
        warn("[Config] Load failed: invalid file")
        return false
    end

    -- Apply config values
    if result.enabled ~= nil then enabled = result.enabled end
    if result.AUTO_SELL ~= nil then AUTO_SELL = result.AUTO_SELL end
    if result.AUTO_COLLECT ~= nil then AUTO_COLLECT = result.AUTO_COLLECT end
    if result.ANTI_AFK ~= nil then ANTI_AFK = result.ANTI_AFK end
    if result.HIDE_OTHER_PLOTS ~= nil then
        HIDE_OTHER_PLOTS = result.HIDE_OTHER_PLOTS
        setOtherPlotsHidden(HIDE_OTHER_PLOTS)
    end
    if result.AUTO_PETS ~= nil then AUTO_PETS = result.AUTO_PETS end
    if result.autoBuySeeds ~= nil then autoBuySeeds = result.autoBuySeeds end
    if result.autoBuyGear ~= nil then autoBuyGear = result.autoBuyGear end
    if result.autoBuyCrates ~= nil then autoBuyCrates = result.autoBuyCrates end
    if result.LOOP_INTERVAL ~= nil then LOOP_INTERVAL = result.LOOP_INTERVAL end
    if result.POLL_INTERVAL ~= nil then POLL_INTERVAL = result.POLL_INTERVAL end
    if result.COLLECT_INTERVAL ~= nil then COLLECT_INTERVAL = result.COLLECT_INTERVAL end
    if result.TP_SETTLE ~= nil then TP_SETTLE = result.TP_SETTLE end
    if result.RETURN_TO_START ~= nil then RETURN_TO_START = result.RETURN_TO_START end
    if result.selectedSeeds ~= nil then selectedSeeds = result.selectedSeeds end
    if result.selectedGear ~= nil then selectedGear = result.selectedGear end
    if result.selectedCrates ~= nil then selectedCrates = result.selectedCrates end
    if result.selectedPetNames ~= nil then selectedPetNames = result.selectedPetNames end

    print("[Config] Loaded '" .. name .. "'")
    return true
end

local function listConfigs()
    ensureConfigFolder()
    local files = listfiles(CONFIG_FOLDER)
    local configs = {}
    for _, path in ipairs(files) do
        local name = path:match(CONFIG_FOLDER .. "/(.+)%.json$")
        if name then
            table.insert(configs, name)
        end
    end
    return configs
end

local function deleteConfig(name)
    local path = getConfigPath(name)
    if isfile(path) then
        delfile(path)
        print("[Config] Deleted '" .. name .. "'")
        return true
    end
    return false
end

