local function parseStock(itemFrame)
	local main = itemFrame:FindFirstChild("Main_Frame")
	if not main then return nil end
	local stockLabel = main:FindFirstChild("Stock_Text")
	if not stockLabel then return nil end
	local n = string.match(stockLabel.Text, "x(%d+)")
	return tonumber(n) or 0
end

local function readShopStock(scrollFrame)
	local list = {}
	if not scrollFrame then return list end
	for _, frame in ipairs(scrollFrame:GetChildren()) do
		if frame:IsA("Frame") and frame:FindFirstChild("Main_Frame") then
			local stock = parseStock(frame)
			if stock and stock > 0 then
				table.insert(list, { name = frame.Name, stock = stock })
			end
		end
	end
	return list
end

local function getSeedShopFrame()
	local gui = player.PlayerGui:FindFirstChild("SeedShop")
	if not gui then return nil end
	local frame = gui:FindFirstChild("Frame")
	return frame and frame:FindFirstChild("NormalShop") or nil
end
local function getGearShopFrame()
	local gui = player.PlayerGui:FindFirstChild("GearShop")
	if not gui then return nil end
	local frame = gui:FindFirstChild("Frame")
	return frame and (frame:FindFirstChild("NormalShop") or frame:FindFirstChild("Shop")) or nil
end
local function getCrateShopFrame()
	local gui = player.PlayerGui:FindFirstChild("CrateShop")
	if not gui then return nil end
	local frame = gui:FindFirstChild("Frame")
	return frame and (frame:FindFirstChild("NormalShop") or frame:FindFirstChild("Shop")) or nil
end

local function buyItem(remote, name, count)
	for _ = 1, count do
		if not running then break end
		pcall(function() remote:Fire(name) end)
		task.wait(0.08)
	end
end

local function buyShop(getFrame, remote, filter)
	for _, item in ipairs(readShopStock(getFrame())) do
		if filter == nil or filter[item.name] then
			buyItem(remote, item.name, item.stock)
		end
	end
end

local function buyAllSeeds()  buyShop(getSeedShopFrame,  Networking.SeedShop.PurchaseSeed,  nil); print("[Shop] seeds done")  end
local function buyAllGear()   buyShop(getGearShopFrame,  Networking.GearShop.PurchaseGear,  nil); print("[Shop] gear done")   end
local function buyAllCrates() buyShop(getCrateShopFrame, Networking.CrateShop.PurchaseCrate, nil); print("[Shop] crates done") end

