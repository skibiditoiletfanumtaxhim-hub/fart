		b.Parent           = header
		corner(b, 7)
		track(b.MouseEnter:Connect(function() tw(b, TW_FAST, { BackgroundColor3 = Theme.Accent }) end))
		track(b.MouseLeave:Connect(function() tw(b, TW_FAST, { BackgroundColor3 = color }) end))
		return b
	end

	local content
	local minimized = false
	local minBtn = makeHeaderBtn("-", -76, Theme.Off)
	local unloadBtn = makeHeaderBtn("X", -40, Theme.AccentDk)

	track(unloadBtn.MouseButton1Click:Connect(function()
		tw(main, TW_FAST, { Size = UDim2.fromOffset(420, 0) })
		task.wait(0.18)
		unloadEverything()
	end))

	local tabBar = Instance.new("Frame")
	tabBar.Size             = UDim2.new(1, -20, 0, 34)
	tabBar.Position         = UDim2.fromOffset(10, 54)
	tabBar.BackgroundTransparency = 1
	tabBar.Parent           = main
	self.tabBar = tabBar

	local tabLayout = Instance.new("UIListLayout")
	tabLayout.FillDirection = Enum.FillDirection.Horizontal
	tabLayout.Padding       = UDim.new(0, 6)
	tabLayout.SortOrder     = Enum.SortOrder.LayoutOrder
	tabLayout.Parent        = tabBar

	content = Instance.new("Frame")
	content.Size             = UDim2.new(1, -20, 1, -100)
	content.Position        = UDim2.fromOffset(10, 94)
	content.BackgroundColor3 = Theme.Panel
	content.BorderSizePixel  = 0
	content.Parent           = main
	corner(content, 10)
	self.content = content

	track(minBtn.MouseButton1Click:Connect(function()
		minimized = not minimized
		if minimized then
			tw(main, TW_MED, { Size = UDim2.fromOffset(420, 100) })
			content.Visible = false
		else
			content.Visible = true
			tw(main, TW_MED, { Size = UDim2.fromOffset(420, 360) })
		end
	end))

	local dragging, dragStart, startPos
	track(header.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true; dragStart = input.Position; startPos = main.Position
		end
	end))
	track(UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - dragStart
			main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
		end
	end))
	track(UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end))

	return self
end

function Library:AddTab(name)
	local btn = Instance.new("TextButton")
	btn.Size             = UDim2.new(0, 78, 1, 0)
	btn.BackgroundColor3 = Theme.Tab
	btn.BorderSizePixel  = 0
