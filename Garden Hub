-- just like selecting seeds whether or not they're in stock)
--------------------------------------------------------------------
local function addKnownPet(name)
	if type(name) == "string" and name ~= "" and not knownPetNames[name] then
		knownPetNames[name] = true
		return true
	end
	return false
end

local function findPetAssetsFolder()
	local assets = ReplicatedStorage:FindFirstChild("Assets")
	return assets and assets:FindFirstChild("Pets") or nil
end

-- Canonical roster, straight from Assets.Pets (plain model names = pet names),
-- the pet-tab equivalent of reading the seed shop frame.
local function refreshKnownPetsFromAssets()
	local folder = findPetAssetsFolder()
	if not folder then return 0 end
	local added = 0
	for _, child in ipairs(folder:GetChildren()) do
		if addKnownPet(child.Name) then added += 1 end
	end
	return added
end

-- Names from spawned pets are guaranteed to match the filter, since they come
-- from the same petInfo() the tamer compares against. Picks up any oddball not
-- listed in Assets.Pets.
local function refreshKnownPetsFromWorld()
	local folder = findWildPetsFolder()
	if folder then
		for _, m in ipairs(folder:GetChildren()) do
			if m:IsA("Model") or m:IsA("Folder") then
				addKnownPet((petInfo(m)))
			end
		end
	end
	for name in pairs(selectedPetNames) do addKnownPet(name) end -- keep loaded selections visible
end

-- Best-effort "is this wild pet already tamed / gone" check so we don't
-- teleport to a pet that no longer needs taming. A tamed pet is usually removed
-- from the spawn folder; the attribute checks catch cases where it lingers.
local function isPetTamed(model)
	if not model then return false end                          -- ref-only path, can't tell -> attempt
	if not model:IsDescendantOf(Workspace) then return true end -- removed = tamed/despawned
	if model:GetAttribute("Tamed") == true then return true end
	if model:GetAttribute("Claimed") == true then return true end
	local owner = model:GetAttribute("Owner")
		or model:GetAttribute("TamedBy")
		or model:GetAttribute("OwnerName")
	if owner ~= nil and owner ~= "" then return true end
	if model:FindFirstChild("Owner") or model:FindFirstChild("Tamed") then return true end
	return false
end

local function findWildPetRefFolder()
	local map = Workspace:FindFirstChild("Map")
	return map and map:FindFirstChild("WildPetRef") or nil
end

-- Resolve a spawn model (which carries the pet type for filtering) to the ref
-- part in Workspace.Map.WildPetRef that WildPetTame actually wants.
local function getPetRefPart(model)
	local refFolder = findWildPetRefFolder()
	if not refFolder then return nil end

	local _, id = petInfo(model)
	if id then
		local exact = refFolder:FindFirstChild("WildPet_" .. id)
		if exact then return exact end
		for _, p in ipairs(refFolder:GetChildren()) do
			if p.Name:find(id, 1, true) then return p end
		end
	end

	local modelPart = model:FindFirstChild("RootPart") or model:FindFirstChildWhichIsA("BasePart", true)
	if modelPart then
		local best, bestDist
		for _, p in ipairs(refFolder:GetChildren()) do
			if p:IsA("BasePart") then
				local d = (p.Position - modelPart.Position).Magnitude
				if not bestDist or d < bestDist then best, bestDist = p, d end
			end
		end
		if best and bestDist and bestDist < 30 then return best end
	end
	return nil
end

local function enterTame()
	tameDepth += 1
	petTaming = true
end
local function exitTame()
	tameDepth = math.max(0, tameDepth - 1)
	if tameDepth == 0 then petTaming = false end
end

-- Per-part cooldown: don't keep teleporting to a pet that won't tame (e.g. full
-- pet slots). Weak keys so tamed/removed parts clear themselves.
local tameCooldown = setmetatable({}, { __mode = "k" })
local TAME_RETRY   = 5

-- Fire WildPetTame on a ref part. WildPetTame is distance-checked server-side,
-- so if TAME_TELEPORT is on we hop to the pet, fire, HOLD, then hop back.
local TAME_WALKSPEED = 60    -- lower = less likely to ram parts; raise if too slow
local TAME_HOLD      = 0.6   -- seconds parked ON the pet after firing, before returning

local function fireTameAt(part, model)
	if not (part and (part:IsA("BasePart") or part:IsA("Model"))) then return false end
	if model and isPetTamed(model) then return false end         -- already tamed -> don't bother
	if not part:IsDescendantOf(Workspace) then return false end  -- ref part gone -> skip

	local now = os.clock()
	if (now - (tameCooldown[part] or -math.huge)) < TAME_RETRY then return false end
	tameCooldown[part] = now

	local char = character or player.Character
	local hrp  = char and char:FindFirstChild("HumanoidRootPart")
	local hum  = char and char:FindFirstChildWhichIsA("Humanoid")
	if not hrp then return false end

	taming = true
	enterTame()

	local pos    = part:IsA("BasePart") and part.Position or part:GetPivot().Position
	local origin = hrp.CFrame

	if TAME_TELEPORT then
		-- Teleport directly ON the pet so we ALWAYS reach it, fire repeatedly
		-- while parked, HOLD long enough for the server to register, THEN return.
		-- (This is what fixes the "teleports back before reaching" failures.)
		hrp.CFrame = CFrame.new(pos + Vector3.new(0, 3, 0))
		task.wait(TP_SETTLE)

		for _ = 1, 5 do
			if model and isPetTamed(model) then break end -- stop firing the instant it tames
			pcall(function() Networking.Pets.WildPetTame:Fire(part) end)
			task.wait(0.12)
		end

		task.wait(TAME_HOLD)                               -- DO NOT return early
		local h = getHRP()
		if h then h.CFrame = getReturnCFrame(origin) end
	else
		-- Walk path: disable collisions, move to the pet, and only fire AFTER we
		-- have actually arrived. If we never get close, skip rather than fire blind.
		local originalSpeed = hum and hum.WalkSpeed or 16
		local restoreCollide = {}
		for _, d in ipairs(char:GetDescendants()) do
			if d:IsA("BasePart") and d.CanCollide then
				restoreCollide[d] = true
				d.CanCollide = false
			end
		end
		if hum then hum.WalkSpeed = TAME_WALKSPEED end

		local arrived = false
		local conn = hum and hum.MoveToFinished:Connect(function(reached) arrived = reached end)
		if hum then hum:MoveTo(pos) end

		local waited = 0
		while not arrived and waited < 5 do
			if hum then hum:MoveTo(pos) end
			task.wait(0.1)
			waited += 0.1
			if (hrp.Position - pos).Magnitude < 8 then arrived = true end
			if model and isPetTamed(model) then break end
		end
		if conn then conn:Disconnect() end

		if arrived and (hrp.Position - pos).Magnitude < 12 then
			for _ = 1, 4 do
				if model and isPetTamed(model) then break end
				pcall(function() Networking.Pets.WildPetTame:Fire(part) end)
				task.wait(0.1)
			end
			task.wait(TAME_HOLD)
		end

		for d in pairs(restoreCollide) do
			if d and d.Parent then d.CanCollide = true end
		end
		if hum then hum.WalkSpeed = originalSpeed end
	end

	taming = false
	exitTame()
	return true
end

local function tameWildPet(model)
	if isPetTamed(model) then return end
	fireTameAt(getPetRefPart(model), model)
end

local function autoTamePets()
	enterTame()

	-- Primary path: iterate spawned pet MODELS so we can read tamed-state and
	-- skip pets that are already tamed (fixes "still goes for an already-tamed pet").
	local spawnFolder = findWildPetsFolder()
	if spawnFolder then
		for _, model in ipairs(spawnFolder:GetChildren()) do
			if not (running and AUTO_PETS) then break end
			if (model:IsA("Model") or model:IsA("Folder")) then
				if petMatchesFilters(model) and not isPetTamed(model) then
					fireTameAt(getPetRefPart(model), model)
				end
			end
		end
		exitTame()
		return
	end

	-- Fallback: no spawn folder available -> tame via ref parts directly
	-- (no per-pet tamed info here, but the cooldown still prevents spam).
	local refFolder = findWildPetRefFolder()
	if refFolder then
		for _, part in ipairs(refFolder:GetChildren()) do
			if not (running and AUTO_PETS) then break end
			fireTameAt(part, nil)
		end
	end
	exitTame()
end

local function testTameFirstPet()
	local folder = findWildPetsFolder()
	if not folder then warn("[Pets] No wild pet folder found.") return end
	for _, model in ipairs(folder:GetChildren()) do
		if (model:IsA("Model") or model:IsA("Folder")) and petMatchesFilters(model) then
			local name = petInfo(model)
			local refPart = getPetRefPart(model)
			if not refPart then
				warn("[Pets] Couldn't find a WildPetRef part for " .. model.Name)
				return
			end
			print("[Pets] Taming " .. tostring(name) .. " via " .. refPart:GetFullName()
				.. (TAME_TELEPORT and "  (teleport ON)" or "  (teleport OFF)"))
			tameCooldown[refPart] = nil -- allow an immediate manual test
			task.spawn(function() fireTameAt(refPart, model) end)
			return
		end
	end
	warn("[Pets] No matching wild pets to test on.")
end

local captureInstalled = false
local CAPTURE_DENYLIST = {
	["Garden.CollectFruit"] = true,
	["SeedShop.PurchaseSeed"] = true,
	["GearShop.PurchaseGear"] = true,
	["CrateShop.PurchaseCrate"] = true,
	["NPCS.SellAll"] = true,
	["ObjectPositionService.CreateServerValue"] = true,
    ["Steal.BeginSteal"] = true,
}

local function describeArg(i, v)
	local t = typeof(v)
	if t == "Instance" then
		return string.format("[%d] Instance(%s) = %s", i, v.ClassName, v:GetFullName())
	elseif t == "table" then
		local ok, encoded = pcall(function() return HttpService:JSONEncode(v) end)
		return string.format("[%d] table = %s", i, ok and encoded or "<unencodable table>")
	else
		return string.format("[%d] %s = %s", i, t, tostring(v))
	end
end

local captureLastPrint = {}
local captureKeywords = nil
local function labelMatchesFilter(label)
	if not captureKeywords then return true end
	local low = label:lower()
	for _, kw in ipairs(captureKeywords) do
		if low:find(kw, 1, true) then return true end
	end
	return false
end

local function wrapRemoteFire(label, remote)
	local orig = remote.Fire
	if type(orig) ~= "function" then return end
	remote.Fire = function(selfRef, ...)
		if not CAPTURE_DENYLIST[label] and labelMatchesFilter(label) then
			local now = os.clock()
			if (now - (captureLastPrint[label] or -math.huge)) >= 1 then
				captureLastPrint[label] = now
				local n = select("#", ...)
				local parts = {}
				for i = 1, n do
					parts[i] = describeArg(i, (select(i, ...)))
				end
				pcall(function()
					print("[CAPTURE] " .. label .. ":Fire(" .. table.concat(parts, ", ") .. ")")
				end)
			end
		end
		return orig(selfRef, ...)
	end
end

local function installCapture(focused)
	captureKeywords = focused and { "pet", "tame", "wild", "steal" } or nil

	if captureInstalled then
		print("[Capture] Filter set to: " .. (focused and "PET/STEAL-ONLY" or "everything"))
		return
	end
	captureInstalled = true
	local count = 0
	for serviceName, service in pairs(Networking) do
		if type(service) == "table" then
			if type(service.Fire) == "function" and service.Id ~= nil then
				wrapRemoteFire(serviceName, service); count += 1
			else
				for remoteName, remote in pairs(service) do
					if type(remote) == "table" and type(remote.Fire) == "function" then
						wrapRemoteFire(serviceName .. "." .. remoteName, remote); count += 1
					end
				end
			end
		end
	end
	print(string.format("[Capture] Installed on %d remotes. Filter: %s", count, focused and "FOCUSED" or "everything"))
end

