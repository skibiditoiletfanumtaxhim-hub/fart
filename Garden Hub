--==================================================================
-- AUTO SKIP LOADING SCREEN  (no remote -- the skip is purely client-side)
--==================================================================
-- ReplicatedFirst.LoadingScreenController gates its skip on two local boolean
-- upvalues of a UserInputService.InputBegan connection: u119 ("can skip now")
-- and u117 ("skip pressed"). Setting both true makes the controller run its own
-- proper teardown (unanchor character, re-enable prompts, restore other GUIs),
-- which is far safer than just destroying the loading GUI ourselves.
local getconns = getconnections or get_signal_cons or (getgenv and getgenv().getconnections)
local getups   = (debug and debug.getupvalues) or getupvalues
local setup    = (debug and debug.setupvalue) or setupvalue

local function trySkipLoadingScreen()
	if not (getconns and setup) then
		warn("[Skip] Executor lacks getconnections/setupvalue - cannot skip.")
		return false
	end
	local ok, conns = pcall(getconns, UserInputService.InputBegan)
	if not ok or not conns then return false end

	for _, conn in ipairs(conns) do
		local fn = conn.Function or conn.Func or conn.fn
		if typeof(fn) == "function" then
			-- Match 1: closure lives in the loading-screen script.
			local sOK, src = pcall(function() return debug.info(fn, "s") end)
			local looksRight = (sOK and type(src) == "string" and src:lower():find("loading")) and true or false

			-- Match 2 (fallback): closure has exactly 2 boolean upvalues (u119, u117).
			local ups
			if getups then local u; u, ups = pcall(getups, fn); if not u then ups = nil end end
			if not looksRight and ups then
				local c, allBool = 0, true
				for _, v in pairs(ups) do c += 1; if type(v) ~= "boolean" then allBool = false end end
				looksRight = (c == 2 and allBool)
			end

			if looksRight then
				local set = false
				local n = (ups and #ups ~= 0) and #ups or 2
				for i = 1, n do if pcall(setup, fn, i, true) then set = true end end
				if set then print("[Skip] Loading screen skip flags set."); return true end
			end
		end
	end
	return false
end

-- The skip only matters while the controller is still running (i.e. right after
-- joining). StarterPlayerScripts can start a hair before the loading GUI exists,
-- so retry for a few seconds. Most useful when this is in your autoload config.
local function runAutoSkip()
	task.spawn(function()
		local deadline = os.clock() + 8
		while running and AUTO_SKIP_LOADING and os.clock() < deadline do
			if trySkipLoadingScreen() then break end
			task.wait(0.1)
		end
	end)
end

--==================================================================
-- CORE LOGIC
--==================================================================
local function firePrompt(prompt)
	if not prompt or not prompt:IsA("ProximityPrompt") then return end
	if not prompt.Enabled then return end
	if prompt.ActionText == "" and prompt.ObjectText == "" then return end
	pcall(function()
		prompt.MaxActivationDistance = math.huge
		prompt.RequiresLineOfSight   = false
		prompt.HoldDuration          = 0
		prompt:InputHoldBegin()
		prompt:InputHoldEnd()
	end)
end

local function getHRP()
	local char = character or player.Character
	return char and char:FindFirstChild("HumanoidRootPart") or nil
end

local function getMyGarden()
	local gardens = Workspace:FindFirstChild("Gardens")
	if not gardens then return nil end
	for _, model in ipairs(gardens:GetChildren()) do
		if model:GetAttribute("Owner") == player.Name then return model end
	end
	return nil
end

local function getGardenCenterCFrame()
	local garden = getMyGarden()
	if not garden then return nil end

	local ref = garden:FindFirstChild("PlotSizeReference", true)
	if ref and ref:IsA("BasePart") then
		return CFrame.new(ref.Position + Vector3.new(0, 3, 0))
	end

	-- Fallback if the reference part is missing.
	return CFrame.new(garden:GetPivot().Position + Vector3.new(0, 3, 0))
end

-- When Stay in Center is on, every teleport returns you to your garden's
-- center instead of wherever you happened to be standing.
local function getReturnCFrame(savedCFrame)
	if STAY_IN_CENTER then
		local center = getGardenCenterCFrame()
		if center then return center end
	end
	return savedCFrame
end

local function getOtherGardens()
	local gardens = Workspace:FindFirstChild("Gardens")
	if not gardens then return {} end
	local list = {}
	for _, model in ipairs(gardens:GetChildren()) do
		if model:GetAttribute("Owner") ~= player.Name then
			table.insert(list, model)
		end
	end
	return list
end

local function activateHarvestPrompts()
	local garden = getMyGarden();
	if not garden then return end
	local plants = garden:FindFirstChild("Plants");  if not plants then return end

	-- StreamingEnabled unloads distant plants/fruits; stream them in around the
	-- garden WITHOUT moving the character (no-op if streaming is off).
	pcall(function()
		local pos = garden:GetPivot().Position
		player:RequestStreamAroundAsync(pos)
	end)

	for _, plant in ipairs(plants:GetChildren()) do
		if not (enabled and running) then break end
		local plantId = plant:GetAttribute("PlantId")
		local fruits  = plant:FindFirstChild("Fruits")
		if plantId and fruits then
			for _, fruit in ipairs(fruits:GetChildren()) do
				local fruitId = fruit:GetAttribute("FruitId")
				if fruitId then
					pcall(function() Networking.Garden.CollectFruit:Fire(plantId, fruitId) end)
				end
			end
		end
		task.wait()
	end
end

local function activateSeedPackPrompts()
	local map = Workspace:FindFirstChild("Map");
	if not map then return end
	local spawns = map:FindFirstChild("SeedPackSpawnServerLocations");  if not spawns then return end
	for _, obj in ipairs(spawns:GetDescendants()) do
		if obj:IsA("ProximityPrompt") then firePrompt(obj) end
	end
end

local function collectSeedPacks()
	local map = Workspace:FindFirstChild("Map");
	if not map then return end
	local spawns = map:FindFirstChild("SeedPackSpawnServerLocations");  if not spawns then return end
	local hrp = getHRP();
	if not hrp then return end
	for _, obj in ipairs(spawns:GetDescendants()) do
		if obj:IsA("ProximityPrompt") and obj.Enabled then
			local part = obj.Parent
			if part and part:IsA("BasePart") then
				local startCFrame = hrp.CFrame
				hrp.CFrame = CFrame.new(part.Position + Vector3.new(0, 3, 0))
				task.wait(TP_SETTLE)
				firePrompt(obj)
				if RETURN_TO_START or STAY_IN_CENTER then
					task.wait(TP_SETTLE)
					hrp.CFrame = getReturnCFrame(startCFrame)
				end
			end
		end
	end
end

local function getFruitLabel()
	local pg = player:FindFirstChild("PlayerGui");
	if not pg then return nil end
	local bg = pg:FindFirstChild("BackpackGui");        if not bg then return nil end
	local bp = bg:FindFirstChild("Backpack");
	if not bp then return nil end
	local inv = bp:FindFirstChild("Inventory");
	if not inv then return nil end
	return inv:FindFirstChild("FruitInventory")
end

local function isInventoryFull()
	local label = getFruitLabel()
	if not label or not label:IsA("TextLabel") then return false end
	local clean = label.Text:gsub("<[^>]->", ""):gsub(",", "")
	local cur, max = string.match(clean, "(%d+)%s*/%s*(%d+)")
	cur, max = tonumber(cur), tonumber(max)
	return cur ~= nil and max ~= nil and cur >= max
end

local function stripVisuals()
	local texClasses = { Decal = true, Texture = true, SurfaceAppearance = true }
	local particleClasses = { ParticleEmitter = true, Trail = true, Beam = true, Smoke = true, Fire = true, Sparkles = true }
	local removed, disabled, smoothed = 0, 0, 0
	for _, obj in ipairs(Workspace:GetDescendants()) do
		if texClasses[obj.ClassName] then
			pcall(function() obj:Destroy() end);
			removed += 1
		elseif particleClasses[obj.ClassName] then
			pcall(function() obj.Enabled = false end); disabled += 1
		elseif obj:IsA("BasePart") then
			pcall(function()
				obj.Material      = Enum.Material.SmoothPlastic
				obj.TopSurface    = Enum.SurfaceType.Smooth
				obj.BottomSurface = Enum.SurfaceType.Smooth
				obj.LeftSurface   = Enum.SurfaceType.Smooth
				obj.RightSurface  = Enum.SurfaceType.Smooth
				obj.FrontSurface  = Enum.SurfaceType.Smooth
				obj.BackSurface   = Enum.SurfaceType.Smooth
				if obj:IsA("MeshPart") then obj.TextureID = "" end
			end)
			smoothed += 1
		end
	end
	print(string.format("[AutoHarvest] Removed %d textures, disabled %d effects, smoothed %d parts.", removed, disabled, smoothed))
end

local hiddenParts = {}
local function setOtherPlotsHidden(hide)
	local gardens = Workspace:FindFirstChild("Gardens")
	if not gardens then return end
	if hide then
		for _, model in ipairs(gardens:GetChildren()) do
			if model:GetAttribute("Owner") ~= player.Name then
				for _, obj in ipairs(model:GetDescendants()) do
					if obj:IsA("BasePart") then
						if hiddenParts[obj] == nil then hiddenParts[obj] = obj.Transparency end
						pcall(function() obj.Transparency = 1 end)
					end
				end
			end
		end
	else
		for part, original in pairs(hiddenParts) do
			if part and part.Parent then pcall(function() part.Transparency = original end) end
		end
		table.clear(hiddenParts)
	end
end

--==================================================================
-- AUTO STEAL LOGIC
--==================================================================
local function isOwnerInGarden(garden)
	local ownerName = garden:GetAttribute("Owner")
	if not ownerName then return false end
	local ownerPlayer = Players:FindFirstChild(ownerName)
	if not ownerPlayer or not ownerPlayer.Character then return false end
	local ownerHRP = ownerPlayer.Character:FindFirstChild("HumanoidRootPart")
	if not ownerHRP then return false end
	local gardenPos = garden:GetPivot().Position
	return (ownerHRP.Position - gardenPos).Magnitude < 120
end

local FruitValueCalc = nil
pcall(function()
	FruitValueCalc = require(ReplicatedStorage.SharedModules.FruitValueCalc)
end)

local function getFruitValue(fruit)
	if not FruitValueCalc then return 0 end
	local fruitName = fruit:GetAttribute("FruitName")
		or fruit:GetAttribute("Name")
		or fruit.Name
	if not fruitName then return 0 end
	local ok, val = pcall(FruitValueCalc, fruitName,
		fruit:GetAttribute("SizeMultiplier"),
		fruit:GetAttribute("Mutation"),
		player,
		fruit:GetAttribute("DecayAlpha")
	)
	return (ok and type(val) == "number") and val or 0
end

local function collectStealTargets()
	local targets = {}
	for _, garden in ipairs(getOtherGardens()) do
		local ownerName = garden:GetAttribute("Owner")
		-- If highest value mode, ignore player filter and owner-present check happens per fruit
		if not STEAL_HIGHEST_VALUE then
			if not selectedStealTargets[ownerName] then continue end
			if isOwnerInGarden(garden) then
				print("[AutoSteal] Skipping " .. ownerName .. " - owner present.")
				continue
			end
		end

		local plants = garden:FindFirstChild("Plants")
		if not plants then continue end

		for _, plant in ipairs(plants:GetChildren()) do
			local fruits = plant:FindFirstChild("Fruits")
			if not fruits then continue end

			for _, fruit in ipairs(fruits:GetChildren()) do
				local harvestPart = fruit:FindFirstChild("HarvestPart")
				if not harvestPart then continue end

				local prompt
				for _, desc in ipairs(harvestPart:GetDescendants()) do
					if desc:IsA("ProximityPrompt") and desc:HasTag("StealPrompt") then
						prompt = desc
						break
					end
				end
				if not prompt or not prompt.Enabled then continue end

				local userId  = tonumber(fruit:GetAttribute("UserId"))
					or tonumber(plant:GetAttribute("UserId"))
					or tonumber(garden:GetAttribute("UserId"))
				local plantId = fruit:GetAttribute("PlantId") or plant:GetAttribute("PlantId")
				local fruitId = fruit:GetAttribute("FruitId")
				if not userId or not plantId then continue end

				table.insert(targets, {
					garden     = garden,
					ownerName  = ownerName,
					fruit      = fruit,
					harvestPart = harvestPart,
					prompt     = prompt,
					userId     = userId,
					plantId    = plantId,
					fruitId    = fruitId,
					value      = getFruitValue(fruit),
				})
			end
		end
	end

	if STEAL_HIGHEST_VALUE then
		table.sort(targets, function(a, b) return a.value > b.value end)
	end

	return targets
end

-- Where stolen fruit gets banked. You confirmed PlotSizeReference is the spot,
-- which is exactly what getGardenCenterCFrame already returns.
local function getDepositCFrame()
	return getGardenCenterCFrame()
end

local function doAutoSteal()
	if stealing then return end

	local nightVal = ReplicatedStorage:FindFirstChild("Night")
	if not nightVal or nightVal.Value ~= true then
		print("[AutoSteal] Not night time, skipping.")
		return
	end

	stealing = true
	local hrp = getHRP()
	if not hrp then stealing = false return end

	local targets = collectStealTargets()
	print(string.format("[AutoSteal] Found %d stealable fruits.", #targets))
	local stolen = 0

	for _, t in ipairs(targets) do
		if not (running and AUTO_STEAL) then break end

		-- Skip if prompt is gone (already stolen by someone else)
		if not t.prompt or not t.prompt.Enabled or not t.prompt:IsDescendantOf(Workspace) then
			continue
		end

		-- In highest value mode, check owner presence per fruit
		if STEAL_HIGHEST_VALUE and isOwnerInGarden(t.garden) then
			print("[AutoSteal] Skipping fruit - owner " .. t.ownerName .. " is in their garden.")
			continue
		end

		-- In target mode, re-check owner hasn't walked in
		if not STEAL_HIGHEST_VALUE and isOwnerInGarden(t.garden) then
			print("[AutoSteal] Owner " .. t.ownerName .. " entered garden, skipping remaining fruits.")
			continue
		end

		hrp.CFrame = CFrame.new(t.harvestPart.Position + Vector3.new(0, 3, 0))
		task.wait(TP_SETTLE)

		-- Mirror a manual steal exactly: BeginSteal -> brief hold -> CompleteSteal.
		-- The old code waited on a Steal.StealStarted client event that this game
		-- never fires, then fired CancelSteal on timeout -- which cancelled every
		-- single steal. A real manual steal only ever fires Begin then Complete.
		pcall(function()
			Networking.Steal.BeginSteal:Fire(t.userId, t.plantId, t.fruitId or "")
		end)
		task.wait(STEAL_HOLD_TIME)       -- let the server channel the steal
		pcall(function() Networking.Steal.CompleteSteal:Fire() end)
		task.wait(0.2)                   -- let the completion resolve before moving on

		stolen += 1
		if STEAL_AMOUNT > 0 and stolen >= STEAL_AMOUNT then
			break                        -- deposit happens after the loop
		end
	end

	local h = getHRP()
	local depositCFrame = getDepositCFrame()
	if h and depositCFrame then
		h.CFrame = depositCFrame
		task.wait(0.6)   -- stand in the deposit zone long enough to bank
	end
	if STEAL_AMOUNT > 0 then
		print(string.format("[AutoSteal] Batch complete: stole %d fruit(s).", stolen))
	end

	stealing = false
end

--==================================================================
-- CONFIG SYSTEM
--==================================================================
local CONFIG_FOLDER = "AutoHarvestConfigs"
local DEFAULT_CONFIG_NAME = "default"
local AUTOLOAD_FILE_PATH = CONFIG_FOLDER .. "/autoload_target.txt"

local function getConfigPath(name)
    return CONFIG_FOLDER .. "/" .. (name or DEFAULT_CONFIG_NAME) .. ".json"
end

local function ensureConfigFolder()
    if not isfolder(CONFIG_FOLDER) then
        makefolder(CONFIG_FOLDER)
    end
end

local function saveConfig(name)
    ensureConfigFolder()
    local config = {
        enabled = enabled,
        AUTO_SELL = AUTO_SELL,
        AUTO_COLLECT = AUTO_COLLECT,
        ANTI_AFK = ANTI_AFK,
        HIDE_OTHER_PLOTS = HIDE_OTHER_PLOTS,
        AUTO_PETS = AUTO_PETS,
        TAME_TELEPORT = TAME_TELEPORT,
        AUTO_STEAL = AUTO_STEAL,
        AUTO_SKIP_LOADING = AUTO_SKIP_LOADING,
        autoBuySeeds = autoBuySeeds,
        autoBuyGear = autoBuyGear,
        autoBuyCrates = autoBuyCrates,
        LOOP_INTERVAL = LOOP_INTERVAL,
        POLL_INTERVAL = POLL_INTERVAL,
        COLLECT_INTERVAL = COLLECT_INTERVAL,
        TP_SETTLE = TP_SETTLE,
        RETURN_TO_START = RETURN_TO_START,
        selectedSeeds = selectedSeeds,
        selectedGear = selectedGear,
        selectedCrates = selectedCrates,
        selectedPetNames = selectedPetNames,
        knownPetNames = knownPetNames,
        selectedStealTargets = selectedStealTargets,
		STEAL_HIGHEST_VALUE = STEAL_HIGHEST_VALUE,
		STAY_IN_CENTER = STAY_IN_CENTER,
        STEAL_AMOUNT = STEAL_AMOUNT,
    }
    local success, err = pcall(function()
        writefile(getConfigPath(name), HttpService:JSONEncode(config))
    end)
    if success then
        print("[Config] Saved '" .. name .. "'")
        return true
    else
        warn("[Config] Save failed: " .. tostring(err))
        return false
    end
end

local function loadConfig(name)
    local path = getConfigPath(name)
    if not isfile(path) then
        warn("[Config] No config found: '" .. name .. "'")
        return false
    end
    local success, result = pcall(function()
        return HttpService:JSONDecode(readfile(path))
    end)
    if not success or type(result) ~= "table" then
        warn("[Config] Load failed: invalid file")
        return false
    end

    if result.enabled ~= nil then enabled = result.enabled end
    if result.AUTO_SELL ~= nil then AUTO_SELL = result.AUTO_SELL end
    if result.AUTO_COLLECT ~= nil then AUTO_COLLECT = result.AUTO_COLLECT end
    if result.ANTI_AFK ~= nil then ANTI_AFK = result.ANTI_AFK end
    if result.HIDE_OTHER_PLOTS ~= nil then
        HIDE_OTHER_PLOTS = result.HIDE_OTHER_PLOTS
        setOtherPlotsHidden(HIDE_OTHER_PLOTS)
    end
    if result.AUTO_PETS ~= nil then AUTO_PETS = result.AUTO_PETS end
    if result.TAME_TELEPORT ~= nil then TAME_TELEPORT = result.TAME_TELEPORT end
    if result.AUTO_STEAL ~= nil then AUTO_STEAL = result.AUTO_STEAL end
    if result.AUTO_SKIP_LOADING ~= nil then AUTO_SKIP_LOADING = result.AUTO_SKIP_LOADING end
    if result.autoBuySeeds ~= nil then autoBuySeeds = result.autoBuySeeds end
    if result.autoBuyGear ~= nil then autoBuyGear = result.autoBuyGear end
    if result.autoBuyCrates ~= nil then autoBuyCrates = result.autoBuyCrates end
    if result.LOOP_INTERVAL ~= nil then LOOP_INTERVAL = result.LOOP_INTERVAL end
    if result.POLL_INTERVAL ~= nil then POLL_INTERVAL = result.POLL_INTERVAL end
    if result.COLLECT_INTERVAL ~= nil then COLLECT_INTERVAL = result.COLLECT_INTERVAL end
    if result.TP_SETTLE ~= nil then TP_SETTLE = result.TP_SETTLE end
    if result.RETURN_TO_START ~= nil then RETURN_TO_START = result.RETURN_TO_START end
    if result.selectedSeeds ~= nil then selectedSeeds = result.selectedSeeds end
    if result.selectedGear ~= nil then selectedGear = result.selectedGear end
    if result.selectedCrates ~= nil then selectedCrates = result.selectedCrates end
    if result.selectedPetNames ~= nil then selectedPetNames = result.selectedPetNames end
    -- Merge (never shrink) the known-pet roster across configs.
    if type(result.knownPetNames) == "table" then
        for petName in pairs(result.knownPetNames) do knownPetNames[petName] = true end
    end
    if result.selectedStealTargets ~= nil then selectedStealTargets = result.selectedStealTargets end
	if result.STEAL_HIGHEST_VALUE ~= nil then STEAL_HIGHEST_VALUE = result.STEAL_HIGHEST_VALUE end
	if result.STAY_IN_CENTER ~= nil then STAY_IN_CENTER = result.STAY_IN_CENTER end
    if result.STEAL_AMOUNT ~= nil then STEAL_AMOUNT = result.STEAL_AMOUNT end

    print("[Config] Loaded '" .. name .. "'")
    return true
end

local function listConfigs()
