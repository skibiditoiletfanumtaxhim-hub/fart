-- Shop Tab
win:AddLabel(shopTab, "Buy All (in-stock)")
win:AddButton(shopTab, "Buy All Seeds",  function() task.spawn(buyAllSeeds)  end)
win:AddButton(shopTab, "Buy All Gear",   function() task.spawn(buyAllGear)   end)
win:AddButton(shopTab, "Buy All Crates", function() task.spawn(buyAllCrates) end)

win:AddLabel(shopTab, "Auto-Buy Selected")
local _, getAutoBuySeeds, setAutoBuySeeds = win:AddToggle(shopTab, "Auto-Buy Seeds",  autoBuySeeds,  function(v) autoBuySeeds  = v end)
local _, getAutoBuyGear, setAutoBuyGear = win:AddToggle(shopTab, "Auto-Buy Gear",   autoBuyGear,   function(v) autoBuyGear   = v end)
local _, getAutoBuyCrates, setAutoBuyCrates = win:AddToggle(shopTab, "Auto-Buy Crates", autoBuyCrates, function(v) autoBuyCrates = v end)

local function buildChecklist(getFrame, selectionTable, rowStore)
	for _, row in ipairs(rowStore) do row:Destroy() end
	table.clear(rowStore)
	local frame = getFrame()
	if not frame then
		rowStore[#rowStore+1] = win:AddLabel(shopTab, "Open that shop in-game, then Refresh.")
		return
	end
	for _, child in ipairs(frame:GetChildren()) do
		local main = child:IsA("Frame") and child:FindFirstChild("Main_Frame")
		if main and main:FindFirstChild("Stock_Text") then
			local name = child.Name
			local row = win:AddCheck(shopTab, name, selectionTable[name] == true, function(on)
				selectionTable[name] = on or nil
			end)
			rowStore[#rowStore+1] = row
		end
	end
end

local seedRows, gearRows, crateRows = {}, {}, {}

win:AddLabel(shopTab, "Seed Selection")
win:AddButton(shopTab, "Refresh Seed List", function() buildChecklist(getSeedShopFrame, selectedSeeds, seedRows) end)
win:AddLabel(shopTab, "Gear Selection")
win:AddButton(shopTab, "Refresh Gear List", function() buildChecklist(getGearShopFrame, selectedGear, gearRows) end)
win:AddLabel(shopTab, "Crate Selection")
win:AddButton(shopTab, "Refresh Crate List", function() buildChecklist(getCrateShopFrame, selectedCrates, crateRows) end)
buildChecklist(getSeedShopFrame, selectedSeeds, seedRows)

-- Pet Tab
win:AddLabel(petTab, "Wild Pet Auto-Tame")
local _, getAutoPets, setAutoPets = win:AddToggle(petTab, "Auto-Tame Pets", AUTO_PETS, function(v) AUTO_PETS = v end)

local petRows = {}
local function refreshPetNames()
	for _, row in ipairs(petRows) do row:Destroy() end
	table.clear(petRows)
	local folder = findWildPetsFolder()
	local seen = {}
	if folder then
		for _, m in ipairs(folder:GetChildren()) do
			local n = m:GetAttribute("PetName") or m:GetAttribute("DisplayName") or m.Name
			if n and not seen[n] then
				seen[n] = true
				local row = win:AddCheck(petTab, n, selectedPetNames[n] == true, function(on)
					selectedPetNames[n] = on or nil
				end)
				petRows[#petRows+1] = row
			end
		end
	end
	if #petRows == 0 then
		petRows[#petRows+1] = win:AddLabel(petTab, "No wild pets found right now.")
	end
end
win:AddLabel(petTab, "Filter by Name")
win:AddButton(petTab, "Refresh Pet Names", function() refreshPetNames() end)
win:AddButton(petTab, "Debug Pets (check output)", function() debugWildPets() end)
win:AddButton(petTab, "Test Tame First Pet", function() testTameFirstPet() end)

-- Visual Tab
win:AddLabel(visualTab, "Performance")
win:AddButton(visualTab, "Strip Textures + Particles", function() stripVisuals() end)
win:AddLabel(visualTab, "Removes decals/textures, smooths parts,")
win:AddLabel(visualTab, "disables particles/trails/beams/smoke/fire.")

-- Config Tab
win:AddLabel(configTab, "Save / Load Configs")

local currentConfigName = DEFAULT_CONFIG_NAME
local configNameBox

-- Forward-declare so the Save/Delete button callbacks below capture the
-- real function as an upvalue instead of a nil global.
local refreshConfigList

local _, configBox = win:AddTextBox(configTab, "Config Name", "default", function(text)
	currentConfigName = text:gsub("[^%w_-]", ""):sub(1, 32)
	if currentConfigName == "" then currentConfigName = DEFAULT_CONFIG_NAME end
end)
configNameBox = configBox
configNameBox.Text = currentConfigName

local function applyLoadedStateToUI()
	setEnabled(enabled)
	setAutoSell(AUTO_SELL)
	setAutoCollect(AUTO_COLLECT)
	setHidePlots(HIDE_OTHER_PLOTS)
	setAntiAfk(ANTI_AFK)
	setAutoPets(AUTO_PETS)
	setAutoBuySeeds(autoBuySeeds)
	setAutoBuyGear(autoBuyGear)
	setAutoBuyCrates(autoBuyCrates)
	buildChecklist(getSeedShopFrame, selectedSeeds, seedRows)
	buildChecklist(getGearShopFrame, selectedGear, gearRows)
	buildChecklist(getCrateShopFrame, selectedCrates, crateRows)
	refreshPetNames()
end

win:AddButton(configTab, "Save Config", function()
	local name = currentConfigName
	local success = saveConfig(name)
	if success then
		refreshConfigList()
	end
end)

win:AddButton(configTab, "Load Config", function()
	local name = currentConfigName
	if loadConfig(name) then
		applyLoadedStateToUI()
	end
end)

-- AUTOLOAD SELECTION BUTTON
win:AddButton(configTab, "Set as Autoload", function()
	ensureConfigFolder()
	local success, err = pcall(function()
		writefile(AUTOLOAD_FILE_PATH, currentConfigName)
	end)
	if success then
		print("[Config] '" .. currentConfigName .. "' has been set as the startup config.")
	else
		warn("[Config] Failed to set autoload: " .. tostring(err))
	end
end)

win:AddButton(configTab, "Delete Config", function()
	deleteConfig(currentConfigName)
	refreshConfigList()
end)

win:AddLabel(configTab, "Saved Configs")
local configListLabel = win:AddLabel(configTab, "None")

function refreshConfigList()
	local configs = listConfigs()
	if #configs == 0 then
		configListLabel.Text = "NONE"
	else
		configListLabel.Text = table.concat(configs, ", ")
	end
end

win:AddButton(configTab, "Refresh List", function()
	refreshConfigList()
end)

-- Dynamically check for a saved autoload preference on startup
pcall(function()
	local targetConfig = DEFAULT_CONFIG_NAME
	if isfile(AUTOLOAD_FILE_PATH) then
		local savedTarget = readfile(AUTOLOAD_FILE_PATH)
		if savedTarget and savedTarget ~= "" then
			targetConfig = savedTarget
		end
	end

	if loadConfig(targetConfig) then
		applyLoadedStateToUI()

		-- Sync the UI Textbox to match what was loaded
		if configNameBox then
			configNameBox.Text = targetConfig
			currentConfigName = targetConfig
		end
	end
end)

refreshConfigList()
