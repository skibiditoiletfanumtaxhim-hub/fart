local function buildChecklist(getFrame, selectionTable, rowStore)
	for _, row in ipairs(rowStore) do row:Destroy() end
	table.clear(rowStore)
	local frame = getFrame()
	if not frame then
		rowStore[#rowStore+1] = win:AddLabel(shopTab, "Open that shop in-game, then Refresh.")
		return
	end
	for _, child in ipairs(frame:GetChildren()) do
		local main = child:IsA("Frame") and child:FindFirstChild("Main_Frame")
		if main and main:FindFirstChild("Stock_Text") then
			local name = child.Name
			local row = win:AddCheck(shopTab, name, selectionTable[name] == true, function(on)
				selectionTable[name] = on or nil
			end)
			rowStore[#rowStore+1] = row
		end
	end
end

