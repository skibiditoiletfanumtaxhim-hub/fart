	btn.Text             = name
	btn.Parent           = self.tabBar
	corner(btn, 7)

	local page = Instance.new("ScrollingFrame")
	page.Size                   = UDim2.new(1, 0, 1, 0)
	page.BackgroundTransparency = 1
	page.BorderSizePixel        = 0
	page.ScrollBarThickness     = 4
	page.ScrollBarImageColor3   = Theme.Accent
	page.CanvasSize             = UDim2.new(0, 0, 0, 0)
	page.AutomaticCanvasSize    = Enum.AutomaticSize.Y
	page.Visible                = false
	page.Parent                 = self.content

	local pad = Instance.new("UIPadding")
	pad.PaddingTop = UDim.new(0, 12); pad.PaddingBottom = UDim.new(0, 12)
	pad.PaddingLeft = UDim.new(0, 12); pad.PaddingRight = UDim.new(0, 12)
	pad.Parent = page

	local layout = Instance.new("UIListLayout")
	layout.Padding = UDim.new(0, 8)
	layout.SortOrder = Enum.SortOrder.LayoutOrder
	layout.Parent = page

	local tab = { btn = btn, page = page }
	table.insert(self.tabs, tab)

	track(btn.MouseButton1Click:Connect(function()
		for _, t in ipairs(self.tabs) do
			local on = (t == tab)
			t.page.Visible = on
			tw(t.btn, TW_FAST, {
				BackgroundColor3 = on and Theme.TabOn or Theme.Tab,
				TextColor3 = on and Theme.Text or Theme.SubText,
			})
		end
	end))

	if #self.tabs == 1 then
		page.Visible = true
		btn.BackgroundColor3 = Theme.TabOn
		btn.TextColor3 = Theme.Text
	end
	return tab
end

