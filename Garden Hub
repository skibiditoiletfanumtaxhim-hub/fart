local function isOwnerInGarden(garden)
    local ownerName = garden:GetAttribute("Owner")
    if not ownerName then return false end
    local ownerPlayer = Players:FindFirstChild(ownerName)
    if not ownerPlayer or not ownerPlayer.Character then return false end
    local ownerHRP = ownerPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not ownerHRP then return false end
    return (ownerHRP.Position - garden:GetPivot().Position).Magnitude < 120
end

local function getFruitValue(fruit)
    if not FruitValueCalc then return 0 end
    local fruitName = fruit:GetAttribute("FruitName") or fruit:GetAttribute("Name") or fruit.Name
    if not fruitName then return 0 end
    local ok, val = pcall(FruitValueCalc, fruitName,
        fruit:GetAttribute("SizeMultiplier"),
        fruit:GetAttribute("Mutation"),
        player,
        fruit:GetAttribute("DecayAlpha")
    )
    return (ok and type(val) == "number") and val or 0
end

local function collectStealTargets()
    local targets = {}
    for _, garden in ipairs(getOtherGardens()) do
        local ownerName = garden:GetAttribute("Owner")
        if not STEAL_HIGHEST_VALUE then
            if not selectedStealTargets[ownerName] then continue end
            if isOwnerInGarden(garden) then continue end
        end
        local plants = garden:FindFirstChild("Plants")
        if not plants then continue end
        pcall(function() player:RequestStreamAroundAsync(garden:GetPivot().Position) end)

        for _, plant in ipairs(plants:GetChildren()) do
            local fruits = plant:FindFirstChild("Fruits")
            if not fruits then continue end
            for _, fruit in ipairs(fruits:GetChildren()) do
                local harvestPart = fruit:FindFirstChild("HarvestPart")
                if not harvestPart then continue end

                -- Find StealPrompt
                local prompt
                for _, desc in ipairs(harvestPart:GetDescendants()) do
                    if desc:IsA("ProximityPrompt") and desc:HasTag("StealPrompt") then
                        prompt = desc; break
                    end
                end
                if not prompt or not prompt.Enabled then continue end

                -- Get IDs -- check fruit, then plant, then garden attributes
                local userId = tonumber(fruit:GetAttribute("UserId"))
                    or tonumber(plant:GetAttribute("UserId"))
                    or tonumber(garden:GetAttribute("UserId"))
                -- Fallback: look up by owner name
                if not userId then
                    local op = Players:FindFirstChild(ownerName)
                    if op then userId = op.UserId end
                end

                local plantId = fruit:GetAttribute("PlantId") or plant:GetAttribute("PlantId")
                local fruitId = fruit:GetAttribute("FruitId")
                if not userId or not plantId then continue end

                table.insert(targets, {
                    garden      = garden,
                    ownerName   = ownerName,
                    fruit       = fruit,
                    harvestPart = harvestPart,
                    prompt      = prompt,
                    userId      = userId,
                    plantId     = plantId,
                    fruitId     = fruitId,
                    value       = getFruitValue(fruit),
                })
            end
        end
    end
    if STEAL_HIGHEST_VALUE then
        table.sort(targets, function(a, b) return a.value > b.value end)
    end
    return targets
end

local function doAutoSteal()
    if stealing then return end
    local nightVal = ReplicatedStorage:FindFirstChild("Night")
    if not nightVal or nightVal.Value ~= true then return end

    stealing = true
    local hrp = getHRP()
    if not hrp then stealing = false return end

    local targets = collectStealTargets()
    if #targets == 0 then stealing = false return end
    print(string.format("[AutoSteal] %d stealable fruits found.", #targets))

    local stolen = 0
    for _, t in ipairs(targets) do
        if not (running and AUTO_STEAL) then break end

        -- Re-validate prompt still exists and is enabled
        if not t.prompt or not t.prompt.Enabled then continue end
        if not pcall(function() return t.prompt:IsDescendantOf(Workspace) end) then continue end
        if not t.prompt:IsDescendantOf(Workspace) then continue end

        -- Owner check per-fruit
        if isOwnerInGarden(t.garden) then
            print("[AutoSteal] Owner in garden, skipping: " .. t.ownerName)
            continue
        end

        -- Teleport to the fruit (server is distance-gated)
        hrp = getHRP()
        if not hrp then break end
        hrp.CFrame = CFrame.new(t.harvestPart.Position + Vector3.new(0, 3, 0))
        task.wait(TP_SETTLE)

        -- Fire exactly as the game does for instant-trigger prompts
        pcall(function() Networking.Steal.BeginSteal:Fire(t.userId, t.plantId, t.fruitId or "") end)
        task.wait(STEAL_HOLD_TIME)
        pcall(function() Networking.Steal.CompleteSteal:Fire() end)
        task.wait(0.2)

        stolen += 1
        if STEAL_AMOUNT > 0 and stolen >= STEAL_AMOUNT then break end
    end

    -- Return to garden center after steal run
    hrp = getHRP()
    if hrp then
        local center = getGardenCenterCFrame()
        if center then
            hrp.CFrame = center
            task.wait(0.8)
        end
    end

    print(string.format("[AutoSteal] Done. Stole %d fruit(s).", stolen))
    stealing = false
end

