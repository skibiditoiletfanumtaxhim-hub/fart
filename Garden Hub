local function gradient(parent, c1, c2, rot)
	local g = Instance.new("UIGradient")
	g.Color = ColorSequence.new(c1, c2)
	g.Rotation = rot or 90
	g.Parent = parent
	return g
end

local Library = {}
Library.__index = Library

function Library.new(title)
	local self = setmetatable({}, Library)
	self.tabs = {}

	-- Size to the screen. On phones the desktop 420x500 panel overflows, so we
	-- shrink to fit the viewport and dock to the left edge with a small margin.
	local cam = Workspace.CurrentCamera
	local vp  = (cam and cam.ViewportSize) or Vector2.new(1280, 720)
	local isMobile = UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled
	local UI_W   = isMobile and math.floor(math.min(330, vp.X * 0.92)) or 420
	local UI_H   = isMobile and math.floor(math.min(430, vp.Y * 0.82)) or 500
	local UI_MIN = isMobile and 92 or 100
	local UI_X   = isMobile and 8 or 40
	self.uiW, self.uiH, self.uiMin = UI_W, UI_H, UI_MIN
	self.isMobile = isMobile
	self.tabW = isMobile and 58 or 68

	local gui = Instance.new("ScreenGui")
