            remote.Fire = function(self, ...)
                local args = {...}
                local parts = {}
                for i, v in ipairs(args) do
                    local t = typeof(v)
                    if t == "Instance" then
                        parts[i] = string.format("[%d] Instance(%s) = %s", i, v.ClassName, v:GetFullName())
                    else
                        parts[i] = string.format("[%d] %s = %s", i, t, tostring(v))
                    end
                end
                print("[STEAL CAPTURE] Steal." .. remoteName .. ":Fire(" .. table.concat(parts, ", ") .. ")")
                return orig(self, ...)
            end
            print("[STEAL CAPTURE] Hooked Steal." .. remoteName)
        end
    end
    print("[STEAL CAPTURE] Now go manually trigger a steal on someone's garden.")
end)

