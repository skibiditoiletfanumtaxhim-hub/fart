local CONFIG_FOLDER = "AutoHarvestConfigs"
local DEFAULT_CONFIG_NAME = "default"
local AUTOLOAD_FILE_PATH = CONFIG_FOLDER .. "/autoload_target.txt"

local function getConfigPath(name)
    return CONFIG_FOLDER .. "/" .. (name or DEFAULT_CONFIG_NAME) .. ".json"
end

local function ensureConfigFolder()
    if not isfolder(CONFIG_FOLDER) then
        makefolder(CONFIG_FOLDER)
    end
end

local function saveConfig(name)
    ensureConfigFolder()
    local config = {
        enabled = enabled,
        AUTO_SELL = AUTO_SELL,
        AUTO_COLLECT = AUTO_COLLECT,
        ANTI_AFK = ANTI_AFK,
        HIDE_OTHER_PLOTS = HIDE_OTHER_PLOTS,
        AUTO_PETS = AUTO_PETS,
        TAME_TELEPORT = TAME_TELEPORT,
        AUTO_STEAL = AUTO_STEAL,
        autoBuySeeds = autoBuySeeds,
        autoBuyGear = autoBuyGear,
        autoBuyCrates = autoBuyCrates,
        LOOP_INTERVAL = LOOP_INTERVAL,
        POLL_INTERVAL = POLL_INTERVAL,
        COLLECT_INTERVAL = COLLECT_INTERVAL,
        TP_SETTLE = TP_SETTLE,
        RETURN_TO_START = RETURN_TO_START,
        selectedSeeds = selectedSeeds,
        selectedGear = selectedGear,
        selectedCrates = selectedCrates,
        selectedPetNames = selectedPetNames,
        selectedStealTargets = selectedStealTargets,
		STEAL_HIGHEST_VALUE = STEAL_HIGHEST_VALUE,
		STAY_IN_CENTER = STAY_IN_CENTER,
        STEAL_AMOUNT = STEAL_AMOUNT,
    }
    local success, err = pcall(function()
        writefile(getConfigPath(name), HttpService:JSONEncode(config))
    end)
    if success then
        print("[Config] Saved '" .. name .. "'")
        return true
    else
        warn("[Config] Save failed: " .. tostring(err))
        return false
    end
end

local function loadConfig(name)
    local path = getConfigPath(name)
    if not isfile(path) then
        warn("[Config] No config found: '" .. name .. "'")
        return false
    end
    local success, result = pcall(function()
        return HttpService:JSONDecode(readfile(path))
    end)
    if not success or type(result) ~= "table" then
        warn("[Config] Load failed: invalid file")
        return false
    end

    if result.enabled ~= nil then enabled = result.enabled end
    if result.AUTO_SELL ~= nil then AUTO_SELL = result.AUTO_SELL end
    if result.AUTO_COLLECT ~= nil then AUTO_COLLECT = result.AUTO_COLLECT end
    if result.ANTI_AFK ~= nil then ANTI_AFK = result.ANTI_AFK end
    if result.HIDE_OTHER_PLOTS ~= nil then
        HIDE_OTHER_PLOTS = result.HIDE_OTHER_PLOTS
        setOtherPlotsHidden(HIDE_OTHER_PLOTS)
    end
    if result.AUTO_PETS ~= nil then AUTO_PETS = result.AUTO_PETS end
    if result.TAME_TELEPORT ~= nil then TAME_TELEPORT = result.TAME_TELEPORT end
    if result.AUTO_STEAL ~= nil then AUTO_STEAL = result.AUTO_STEAL end
    if result.autoBuySeeds ~= nil then autoBuySeeds = result.autoBuySeeds end
    if result.autoBuyGear ~= nil then autoBuyGear = result.autoBuyGear end
    if result.autoBuyCrates ~= nil then autoBuyCrates = result.autoBuyCrates end
    if result.LOOP_INTERVAL ~= nil then LOOP_INTERVAL = result.LOOP_INTERVAL end
    if result.POLL_INTERVAL ~= nil then POLL_INTERVAL = result.POLL_INTERVAL end
    if result.COLLECT_INTERVAL ~= nil then COLLECT_INTERVAL = result.COLLECT_INTERVAL end
    if result.TP_SETTLE ~= nil then TP_SETTLE = result.TP_SETTLE end
    if result.RETURN_TO_START ~= nil then RETURN_TO_START = result.RETURN_TO_START end
    if result.selectedSeeds ~= nil then selectedSeeds = result.selectedSeeds end
    if result.selectedGear ~= nil then selectedGear = result.selectedGear end
    if result.selectedCrates ~= nil then selectedCrates = result.selectedCrates end
    if result.selectedPetNames ~= nil then selectedPetNames = result.selectedPetNames end
    if result.selectedStealTargets ~= nil then selectedStealTargets = result.selectedStealTargets end
	if result.STEAL_HIGHEST_VALUE ~= nil then STEAL_HIGHEST_VALUE = result.STEAL_HIGHEST_VALUE end
	if result.STAY_IN_CENTER ~= nil then STAY_IN_CENTER = result.STAY_IN_CENTER end
    if result.STEAL_AMOUNT ~= nil then STEAL_AMOUNT = result.STEAL_AMOUNT end

    print("[Config] Loaded '" .. name .. "'")
    return true
end

local function listConfigs()
    ensureConfigFolder()
    local files = listfiles(CONFIG_FOLDER)
    local configs = {}
    for _, path in ipairs(files) do
        local name = path:match(CONFIG_FOLDER .. "/(.+)%.json$")
        if name then
            table.insert(configs, name)
        end
    end
    return configs
end

local function deleteConfig(name)
    local path = getConfigPath(name)
    if isfile(path) then
        delfile(path)
        print("[Config] Deleted '" .. name .. "'")
        return true
    end
    return false
end

