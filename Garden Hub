-- AUTO PETS (wild pet tame)
--==================================================================
local function findWildPetsFolder()
	local map = Workspace:FindFirstChild("Map")
	if not map then return nil end
	-- Try a few likely names; games rename these between updates.
	return map:FindFirstChild("WildPetSpawns")
		or map:FindFirstChild("WildPets")
		or map:FindFirstChild("WildPetSpawn")
		or Workspace:FindFirstChild("WildPetSpawns")
		or nil
end

-- Prints the live wild-pet hierarchy so we can confirm names/paths.
local function debugWildPets()
	local folder = findWildPetsFolder()
	if not folder then
		warn("[Pets] No wild pet folder found. Children of Map:")
		local map = Workspace:FindFirstChild("Map")
		if map then
			for _, c in ipairs(map:GetChildren()) do
				print("   Map > " .. c.Name .. "  (" .. c.ClassName .. ")")
			end
		else
			warn("   Workspace.Map itself is missing.")
		end
		return
	end
	print("[Pets] Found folder: " .. folder:GetFullName())
	local kids = folder:GetChildren()
	print("[Pets] " .. #kids .. " children.")
	for i, m in ipairs(kids) do
		if i > 5 then print("   ... (truncated)"); break end
		print(string.format("   [%d] %s (%s)", i, m.Name, m.ClassName))
		local prompt = m:FindFirstChildWhichIsA("ProximityPrompt", true)
		print("        prompt: " .. (prompt and prompt:GetFullName() or "NONE FOUND"))
	end
end

local function petInfo(model)
	local name = model:GetAttribute("PetName") or model.Name:match("WildPet_([^_]+)") or model.Name
	local id   = model.Name:match("WildPet_[^_]+_WildPet_(.+)")
	return name, id
end

local function petMatchesFilters(model)
	local name = petInfo(model)
	if next(selectedPetNames) == nil then return true end
	return selectedPetNames[name] == true
end

-- Tame a wild pet by firing the dedicated remote directly. No proximity
-- prompt, no teleport -- this is what the BuyPrompt ultimately triggers
-- anyway, so we skip straight to it.
local function tameWildPet(model)
	pcall(function()
		Networking.Pets.WildPetTame:Fire(model)
	end)
end

local function autoTamePets()
	local folder = findWildPetsFolder()
	if not folder then return end
	for _, model in ipairs(folder:GetChildren()) do
		if not (running and AUTO_PETS) then break end
		if (model:IsA("Model") or model:IsA("Folder")) and petMatchesFilters(model) then
			tameWildPet(model)
			task.wait() -- small yield so a big batch doesn't fire all in one frame
		end
	end
end

-- One-shot tester: fires WildPetTame on the first matching pet and reports,
-- so we can confirm the remote argument is correct without the loop running.
local function testTameFirstPet()
	local folder = findWildPetsFolder()
	if not folder then warn("[Pets] No wild pet folder found.") return end
	for _, model in ipairs(folder:GetChildren()) do
		if (model:IsA("Model") or model:IsA("Folder")) and petMatchesFilters(model) then
			local name = petInfo(model)
			print("[Pets] Firing WildPetTame on: " .. model.Name .. "  (name=" .. tostring(name) .. ")")
			local ok, err = pcall(function() Networking.Pets.WildPetTame:Fire(model) end)
			if ok then
				print("[Pets] Fired OK. If nothing happened, the remote may want the pet id string instead of the model -- tell me and I'll switch it.")
			else
				warn("[Pets] Fire errored: " .. tostring(err) .. "  (likely wrong argument type; the id string is the alternative.)")
			end
			return
		end
	end
	warn("[Pets] No matching wild pets to test on.")
end

--==================================================================
-- LOOPS
--==================================================================
task.spawn(function()
	while running do
		task.wait(LOOP_INTERVAL)
		if running and enabled and not sweeping then
			sweeping = true
			if DO_HARVEST    then activateHarvestPrompts()  end
			if DO_SEED_PACKS then activateSeedPackPrompts() end
			sweeping = false
		end
	end
end)

task.spawn(function()
	while running do
		task.wait(1)
		if running and autoBuySeeds then
			pcall(function() buyShop(getSeedShopFrame, Networking.SeedShop.PurchaseSeed, selectedSeeds) end)
		end
		if running and autoBuyGear then
			pcall(function() buyShop(getGearShopFrame, Networking.GearShop.PurchaseGear, selectedGear) end)
		end
		if running and autoBuyCrates then
			pcall(function() buyShop(getCrateShopFrame, Networking.CrateShop.PurchaseCrate, selectedCrates) end)
		end
	end
end)

task.spawn(function()
	while running do
		task.wait(POLL_INTERVAL)
		if running and AUTO_SELL and isInventoryFull() then
			pcall(function()
				local result = Networking.NPCS.SellAll:Fire()
				if result and result.Success then
					print(string.format("[AutoHarvest] Inventory full - sold %d for %s", result.SoldCount, tostring(result.SellPrice)))
				end
			end)
		end
	end
end)

task.spawn(function()
	while running do
		task.wait(COLLECT_INTERVAL)
		if running and AUTO_COLLECT and not collecting then
			collecting = true
			pcall(collectSeedPacks)
			collecting = false
		end
	end
end)

task.spawn(function()
	while running do
		task.wait(0.6)
		if running and AUTO_PETS then
			pcall(autoTamePets)
		end
	end
end)

