local function stripVisuals()
    local texClasses     = { Decal = true, Texture = true, SurfaceAppearance = true }
    local particleClasses = { ParticleEmitter = true, Trail = true, Beam = true, Smoke = true, Fire = true, Sparkles = true }
    local removed, disabled, smoothed = 0, 0, 0
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if texClasses[obj.ClassName] then
            pcall(function() obj:Destroy() end); removed += 1
        elseif particleClasses[obj.ClassName] then
            pcall(function() obj.Enabled = false end); disabled += 1
        elseif obj:IsA("BasePart") then
            pcall(function()
                obj.Material      = Enum.Material.SmoothPlastic
                obj.TopSurface    = Enum.SurfaceType.Smooth
                obj.BottomSurface = Enum.SurfaceType.Smooth
                if obj:IsA("MeshPart") then obj.TextureID = "" end
            end)
            smoothed += 1
        end
    end
    Rayfield:Notify({ Title = "Visuals Stripped", Content = string.format("Removed %d textures, disabled %d effects, smoothed %d parts.", removed, disabled, smoothed), Duration = 4 })
end

local hiddenParts = {}
local function setOtherPlotsHidden(hide)
    local gardens = Workspace:FindFirstChild("Gardens")
    if not gardens then return end
    if hide then
        for _, model in ipairs(gardens:GetChildren()) do
            if model:GetAttribute("Owner") ~= player.Name then
                for _, obj in ipairs(model:GetDescendants()) do
                    if obj:IsA("BasePart") then
                        if hiddenParts[obj] == nil then hiddenParts[obj] = obj.Transparency end
                        pcall(function() obj.Transparency = 1 end)
                    end
                end
            end
        end
    else
        for part, original in pairs(hiddenParts) do
            if part and part.Parent then pcall(function() part.Transparency = original end) end
        end
        table.clear(hiddenParts)
    end
end

--==================================================================
-- AUTO PETS
--==================================================================
local tameCooldown = setmetatable({}, { __mode = "k" })
local TAME_RETRY   = 5
local TAME_HOLD    = 0.8

local function findWildPetsFolder()
    local map = Workspace:FindFirstChild("Map")
    if not map then return nil end
    return map:FindFirstChild("WildPetSpawns")
        or map:FindFirstChild("WildPets")
        or map:FindFirstChild("WildPetSpawn")
        or Workspace:FindFirstChild("WildPetSpawns")
        or nil
end

local function findWildPetRefFolder()
    local map = Workspace:FindFirstChild("Map")
    return map and map:FindFirstChild("WildPetRef") or nil
end

local function petInfo(model)
    local name = model:GetAttribute("PetName")
        or model.Name:match("^WildPet_(.-)_WildPet_")
        or model.Name:match("^WildPet_(.+)$")
        or model.Name
    local id = model.Name:match("WildPet_.-_WildPet_(.+)")
    return name, id
end

local function petMatchesFilters(model)
    local name = petInfo(model)
    if next(selectedPetNames) == nil then return true end
    return selectedPetNames[name] == true
end

local function isPetTamed(model)
    if not model then return false end
    if not model:IsDescendantOf(Workspace) then return true end
    if model:GetAttribute("Tamed") == true then return true end
    if model:GetAttribute("Claimed") == true then return true end
    local owner = model:GetAttribute("Owner") or model:GetAttribute("TamedBy") or model:GetAttribute("OwnerName")
    if owner ~= nil and owner ~= "" then return true end
    return false
end

local function getPetRefPart(model)
    local refFolder = findWildPetRefFolder()
    if not refFolder then return nil end
    local _, id = petInfo(model)
    if id then
        local exact = refFolder:FindFirstChild("WildPet_" .. id)
        if exact then return exact end
        for _, p in ipairs(refFolder:GetChildren()) do
            if p.Name:find(id, 1, true) then return p end
        end
    end
    local modelPart = model:FindFirstChild("RootPart") or model:FindFirstChildWhichIsA("BasePart", true)
    if modelPart then
        local best, bestDist
        for _, p in ipairs(refFolder:GetChildren()) do
            if p:IsA("BasePart") then
                local d = (p.Position - modelPart.Position).Magnitude
                if not bestDist or d < bestDist then best, bestDist = p, d end
            end
        end
        if best and bestDist and bestDist < 30 then return best end
    end
    return nil
end

-- Tame a single pet ref part.
-- STAY_IN_CENTER is intentionally ignored while taming so the center loop
-- never teleports us back before we reach the pet.
local function fireTameAt(part, model)
    if not (part and part:IsDescendantOf(Workspace)) then return false end
    if model and isPetTamed(model) then return false end

    local now = os.clock()
    if (now - (tameCooldown[part] or -math.huge)) < TAME_RETRY then return false end
    tameCooldown[part] = now

    local hrp = getHRP()
    if not hrp then return false end

    taming = true  -- blocks center-return loop

    local pos    = part:IsA("BasePart") and part.Position or part:GetPivot().Position
    local origin = hrp.CFrame

    if TAME_TELEPORT then
        -- Teleport directly onto the pet, fire multiple times, hold, THEN return.
        hrp.CFrame = CFrame.new(pos + Vector3.new(0, 3, 0))
        task.wait(TP_SETTLE)

        for i = 1, 6 do
            if model and isPetTamed(model) then break end
            pcall(function() Networking.Pets.WildPetTame:Fire(part) end)
            task.wait(0.15)
        end
        task.wait(TAME_HOLD)

        -- Only now return — and only if pet is tamed or we've given up
        hrp = getHRP()
        if hrp then
            -- When taming is done, respect STAY_IN_CENTER by going to center,
            -- otherwise go back to origin.
            if STAY_IN_CENTER then
                local center = getGardenCenterCFrame()
                if center then hrp.CFrame = center end
            else
                hrp.CFrame = origin
            end
        end
    else
        -- Walk path
        local hum = getHumanoid()
        local originalSpeed = hum and hum.WalkSpeed or 16
        if hum then hum.WalkSpeed = 60 end

        local arrived = false
        local conn = hum and hum.MoveToFinished:Connect(function(r) arrived = r end)
        if hum then hum:MoveTo(pos) end

        local waited = 0
        while not arrived and waited < 6 do
            if hum then hum:MoveTo(pos) end
            task.wait(0.1); waited += 0.1
            if (hrp.Position - pos).Magnitude < 8 then arrived = true end
            if model and isPetTamed(model) then break end
        end
        if conn then conn:Disconnect() end

        if arrived then
            for _ = 1, 5 do
                if model and isPetTamed(model) then break end
                pcall(function() Networking.Pets.WildPetTame:Fire(part) end)
                task.wait(0.12)
            end
            task.wait(TAME_HOLD)
        end
        if hum then hum.WalkSpeed = originalSpeed end
    end

    taming = false
    return true
end

local function autoTamePets()
    if taming then return end
    local spawnFolder = findWildPetsFolder()
    if spawnFolder then
        for _, model in ipairs(spawnFolder:GetChildren()) do
            if not (running and AUTO_PETS) then break end
            if (model:IsA("Model") or model:IsA("Folder")) and petMatchesFilters(model) and not isPetTamed(model) then
                fireTameAt(getPetRefPart(model), model)
                task.wait(0.1)
            end
        end
        return
    end
    -- fallback: ref folder directly
    local refFolder = findWildPetRefFolder()
    if refFolder then
        for _, part in ipairs(refFolder:GetChildren()) do
            if not (running and AUTO_PETS) then break end
            fireTameAt(part, nil)
            task.wait(0.1)
        end
    end
end

local function testTameFirstPet()
    local folder = findWildPetsFolder()
    if not folder then
        Rayfield:Notify({ Title = "Pets", Content = "No wild pet folder found. Check output.", Duration = 4 })
        warn("[Pets] No wild pet folder found")
        return
    end
    for _, model in ipairs(folder:GetChildren()) do
        if (model:IsA("Model") or model:IsA("Folder")) and petMatchesFilters(model) then
            local name = petInfo(model)
            local refPart = getPetRefPart(model)
            if not refPart then
                Rayfield:Notify({ Title = "Pets", Content = "No WildPetRef part for " .. model.Name, Duration = 4 })
                return
            end
            Rayfield:Notify({ Title = "Pets", Content = "Taming: " .. tostring(name), Duration = 3 })
            tameCooldown[refPart] = nil
            task.spawn(function() fireTameAt(refPart, model) end)
            return
        end
    end
    Rayfield:Notify({ Title = "Pets", Content = "No matching wild pets found.", Duration = 3 })
end

local function addKnownPet(name)
    if type(name) == "string" and name ~= "" and not knownPetNames[name] then
        knownPetNames[name] = true; return true
    end
    return false
end

local function refreshKnownPetsFromAssets()
    local assets = ReplicatedStorage:FindFirstChild("Assets")
    local folder = assets and assets:FindFirstChild("Pets")
    if not folder then return end
    for _, child in ipairs(folder:GetChildren()) do addKnownPet(child.Name) end
end

local function refreshKnownPetsFromWorld()
    local folder = findWildPetsFolder()
    if folder then
        for _, m in ipairs(folder:GetChildren()) do
            if m:IsA("Model") or m:IsA("Folder") then addKnownPet((petInfo(m))) end
        end
    end
    for name in pairs(selectedPetNames) do addKnownPet(name) end
end

local function debugWildPets()
    local folder = findWildPetsFolder()
    if not folder then
        warn("[Pets] No wild pet folder. Map children:")
        local map = Workspace:FindFirstChild("Map")
        if map then for _, c in ipairs(map:GetChildren()) do print("  Map >", c.Name, c.ClassName) end end
        return
    end
    print("[Pets] Folder:", folder:GetFullName())
    for i, m in ipairs(folder:GetChildren()) do
        if i > 8 then print("  ... (truncated)"); break end
        local name, id = petInfo(m)
        local ref = getPetRefPart(m)
        print(string.format("  [%d] %s | name=%s | id=%s | ref=%s | tamed=%s",
            i, m.Name, tostring(name), tostring(id),
            ref and ref:GetFullName() or "NONE",
            tostring(isPetTamed(m))
        ))
    end
end

