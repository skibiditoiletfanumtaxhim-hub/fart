--==================================================================
local function isOwnerInGarden(garden)
	local ownerName = garden:GetAttribute("Owner")
	if not ownerName then return false end
	local ownerPlayer = Players:FindFirstChild(ownerName)
	if not ownerPlayer or not ownerPlayer.Character then return false end
	local ownerHRP = ownerPlayer.Character:FindFirstChild("HumanoidRootPart")
	if not ownerHRP then return false end
	local gardenPos = garden:GetPivot().Position
	return (ownerHRP.Position - gardenPos).Magnitude < 120
end

local FruitValueCalc = nil
pcall(function()
	FruitValueCalc = require(ReplicatedStorage.SharedModules.FruitValueCalc)
end)

local function getFruitValue(fruit)
	if not FruitValueCalc then return 0 end
	local fruitName = fruit:GetAttribute("FruitName")
		or fruit:GetAttribute("Name")
		or fruit.Name
	if not fruitName then return 0 end
	local ok, val = pcall(FruitValueCalc, fruitName,
		fruit:GetAttribute("SizeMultiplier"),
		fruit:GetAttribute("Mutation"),
		player,
		fruit:GetAttribute("DecayAlpha")
	)
	return (ok and type(val) == "number") and val or 0
end

local function collectStealTargets()
	local targets = {}
	for _, garden in ipairs(getOtherGardens()) do
		local ownerName = garden:GetAttribute("Owner")
		-- If highest value mode, ignore player filter and owner-present check happens per fruit
		if not STEAL_HIGHEST_VALUE then
			if not selectedStealTargets[ownerName] then continue end
			if isOwnerInGarden(garden) then
				print("[AutoSteal] Skipping " .. ownerName .. " - owner present.")
				continue
			end
		end

		local plants = garden:FindFirstChild("Plants")
		if not plants then continue end

		for _, plant in ipairs(plants:GetChildren()) do
			local fruits = plant:FindFirstChild("Fruits")
			if not fruits then continue end

			for _, fruit in ipairs(fruits:GetChildren()) do
				local harvestPart = fruit:FindFirstChild("HarvestPart")
				if not harvestPart then continue end

				local prompt
				for _, desc in ipairs(harvestPart:GetDescendants()) do
					if desc:IsA("ProximityPrompt") and desc:HasTag("StealPrompt") then
						prompt = desc
						break
					end
				end
				if not prompt or not prompt.Enabled then continue end

				local userId  = tonumber(fruit:GetAttribute("UserId"))
					or tonumber(plant:GetAttribute("UserId"))
					or tonumber(garden:GetAttribute("UserId"))
				local plantId = fruit:GetAttribute("PlantId") or plant:GetAttribute("PlantId")
				local fruitId = fruit:GetAttribute("FruitId")
				if not userId or not plantId then continue end

				table.insert(targets, {
					garden     = garden,
					ownerName  = ownerName,
					fruit      = fruit,
					harvestPart = harvestPart,
					prompt     = prompt,
					userId     = userId,
					plantId    = plantId,
					fruitId    = fruitId,
					value      = getFruitValue(fruit),
				})
			end
		end
	end

	if STEAL_HIGHEST_VALUE then
		table.sort(targets, function(a, b) return a.value > b.value end)
	end

	return targets
end

-- Where stolen fruit gets banked. You confirmed PlotSizeReference is the spot,
-- which is exactly what getGardenCenterCFrame already returns.
local function getDepositCFrame()
	return getGardenCenterCFrame()
end

local function doAutoSteal()
	if stealing then return end

	local nightVal = ReplicatedStorage:FindFirstChild("Night")
	if not nightVal or nightVal.Value ~= true then
		print("[AutoSteal] Not night time, skipping.")
		return
	end

	stealing = true
	local hrp = getHRP()
	if not hrp then stealing = false return end

	local targets = collectStealTargets()
	print(string.format("[AutoSteal] Found %d stealable fruits.", #targets))
	local stolen = 0

	for _, t in ipairs(targets) do
		if not (running and AUTO_STEAL) then break end

		-- Skip if prompt is gone (already stolen by someone else)
		if not t.prompt or not t.prompt.Enabled or not t.prompt:IsDescendantOf(Workspace) then
			continue
		end

		-- In highest value mode, check owner presence per fruit
		if STEAL_HIGHEST_VALUE and isOwnerInGarden(t.garden) then
			print("[AutoSteal] Skipping fruit - owner " .. t.ownerName .. " is in their garden.")
			continue
		end

		-- In target mode, re-check owner hasn't walked in
		if not STEAL_HIGHEST_VALUE and isOwnerInGarden(t.garden) then
			print("[AutoSteal] Owner " .. t.ownerName .. " entered garden, skipping remaining fruits.")
			continue
		end

		local origin = hrp.CFrame
		hrp.CFrame = CFrame.new(t.harvestPart.Position + Vector3.new(0, 3, 0))
		task.wait(TP_SETTLE)

		local stealConfirmed = false
		local conn = Networking.Steal.StealStarted.OnClientEvent:Connect(function()
			stealConfirmed = true
		end)

		pcall(function()
			Networking.Steal.BeginSteal:Fire(t.userId, t.plantId, t.fruitId or "")
		end)

		local waited = 0
		while not stealConfirmed and waited < 2 do
			task.wait(0.1)
			waited += 0.1
		end
		conn:Disconnect()

		if stealConfirmed then
			-- Hold the steal so the server channels it, THEN complete.
			task.wait(STEAL_HOLD_TIME)
			pcall(function() Networking.Steal.CompleteSteal:Fire() end)
			task.wait(0.3)               -- let the completion resolve before moving
			stolen += 1
			if STEAL_AMOUNT > 0 and stolen >= STEAL_AMOUNT then
				break                    -- deposit happens after the loop
			end
		else
			print("[AutoSteal] No StealStarted within 2s for " .. tostring(t.ownerName) .. " - cancelling.")
			pcall(function() Networking.Steal.CancelSteal:Fire() end)
		end

		task.wait(0.1)
	end

	local h = getHRP()
	local depositCFrame = getDepositCFrame()
	if h and depositCFrame then
		h.CFrame = depositCFrame
		task.wait(0.6)   -- stand in the deposit zone long enough to bank
	end
	if STEAL_AMOUNT > 0 then
		print(string.format("[AutoSteal] Batch complete: stole %d fruit(s).", stolen))
	end

	stealing = false
end

